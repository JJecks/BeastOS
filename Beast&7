    <input id="s-new2" type="password" placeholder="Confirm new passcode" style="width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--border);color:var(--text);padding:0.5rem 0.7rem;border-radius:6px;margin-bottom:0.6rem;font-family:'Rajdhani',sans-serif;font-size:0.9rem;outline:none"/>
    <button onclick="changePass()" style="padding:0.5rem 1.2rem;background:var(--cyan);color:#000;border:none;border-radius:6px;cursor:pointer;font-family:'Orbitron',monospace;font-size:0.65rem;font-weight:700;letter-spacing:0.1em">UPDATE PASSCODE</button>
    <div id="s-msg" style="font-size:0.75rem;margin-top:0.5rem;min-height:1.2em"></div>
  </div>

  <div style="padding:1rem;background:rgba(0,0,0,0.3);border-radius:8px;border:1px solid var(--border)">
    <div style="font-size:0.72rem;font-weight:700;color:var(--dim);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.8rem">Appearance</div>
    <div style="font-size:0.82rem;margin-bottom:0.5rem">Wallpaper</div>
    <div style="display:flex;gap:0.5rem">
      ${[0,1,2].map(i=>`<div onclick="setWallpaper(${i})" style="width:60px;height:40px;border-radius:6px;cursor:pointer;border:2px solid ${osSettings.wallpaper===i?'var(--cyan)':'var(--border)'};background:${['rgba(0,80,180,0.4)','rgba(0,100,60,0.4)','rgba(80,0,160,0.4)'][i]}"></div>`).join('')}
    </div>
  </div>`;
}

function changePass() {
  const old = document.getElementById('s-old').value;
  const nw = document.getElementById('s-new').value;
  const nw2 = document.getElementById('s-new2').value;
  const msg = document.getElementById('s-msg');
  if (djb2Hash(old) !== getPassHash()) { msg.style.color='var(--red)'; msg.textContent='Incorrect current passcode.'; return; }
  if (nw !== nw2) { msg.style.color='var(--red)'; msg.textContent='New passcodes do not match.'; return; }
  if (nw.length < 4) { msg.style.color='var(--red)'; msg.textContent='Passcode too short (min 4 chars).'; return; }
  localStorage.setItem(OS_PASS_KEY, djb2Hash(nw));
  msg.style.color='var(--green)'; msg.textContent='✓ Passcode updated.';
}

function setWallpaper(i) {
  osSettings.wallpaper = i;
  localStorage.setItem(OS_SETTINGS_KEY, JSON.stringify(osSettings));
  const classes = ['wallpaper-1','wallpaper-2','wallpaper-3'];
  document.getElementById('os-bg').className = classes[i] || '';
  renderSettings(document.getElementById('builtin-settings'));
}

// ── TERMINAL ──
let termHistory = [], termIdx = -1;
const TERM_COMMANDS = {
