      <span style="color:#00ff41;font-size:11px">jeckstom@beast:~$</span>
      <input id="term-input" type="text" autocomplete="off"
        style="flex:1;background:transparent;border:none;color:#00ff41;font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;"
        onkeydown="termKey(event)" placeholder="type help"/>
    </div>
  </div>`;
  termPrint('JecksOS Terminal v1.0 — type <span style="color:#ffb000">help</span> for commands');
  setTimeout(() => document.getElementById('term-input')?.focus(), 100);
}

function termPrint(line) {
  const out = document.getElementById('term-out');
  if (!out) return;
  const d = document.createElement('div');
  d.innerHTML = line;
  out.appendChild(d);
  out.scrollTop = out.scrollHeight;
}

function termKey(e) {
  const inp = e.target;
  if (e.key === 'Enter') {
    const cmd = inp.value.trim();
    if (!cmd) return;
    termPrint(`<span style="color:#64748b">$</span> ${cmd}`);
    termHistory.unshift(cmd); termIdx = -1;
    inp.value = '';
    const parts = cmd.split(' ');
    const fn = TERM_COMMANDS[parts[0]];
    if (fn) {
      const out = fn(parts.slice(1).join(' '));
      if (out === '__CLEAR__') document.getElementById('term-out').innerHTML = '';
      else if (out) out.split('\n').forEach(l => termPrint(l));
    } else if (parts[0] === 'open') {
      const id = parts[1];
      if (id && APPS.find(a => a.id === id)) { openApp(id); termPrint(`Opening ${id}...`); }
      else termPrint(`<span style="color:#ff3c3c">App not found: ${parts[1] || '(no id given)'}</span>`);
    } else {
      termPrint(`<span style="color:#ff3c3c">Unknown command: ${parts[0]}</span>`);
    }
  } else if (e.key === 'ArrowUp') {
    termIdx = Math.min(termIdx + 1, termHistory.length - 1);
    inp.value = termHistory[termIdx] || '';
  } else if (e.key === 'ArrowDown') {
    termIdx = Math.max(termIdx - 1, -1);
    inp.value = termIdx >= 0 ? termHistory[termIdx] : '';
  }
}

