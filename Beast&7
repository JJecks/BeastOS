<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>JecksOS · v1.0</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;600;700;900&family=Exo+2:ital,wght@0,200;0,300;0,400;1,200&display=swap" rel="stylesheet"/>
<style>
/* ═══════════════════════════════════════════
   JECKS OS — ROOT VARIABLES & RESET
═══════════════════════════════════════════ */
:root {
  --os-bg:        #04070f;
  --glass:        rgba(10,16,30,0.72);
  --glass2:       rgba(255,255,255,0.04);
  --border:       rgba(255,255,255,0.07);
  --gold:         #c8a84b;
  --gold2:        #f0d07a;
  --gold-glow:    rgba(200,168,75,0.25);
  --cyan:         #00d4ff;
  --cyan2:        #80eeff;
  --cyan-glow:    rgba(0,212,255,0.2);
  --red:          #ff3c3c;
  --green:        #00e676;
  --text:         #d8e4f0;
  --dim:          #4a6080;
  --taskbar-h:    48px;
  --radius:       10px;
}
*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html, body {
  width:100%; height:100%;
  overflow:hidden;
  background:var(--os-bg);
  color:var(--text);
  font-family:'Rajdhani', sans-serif;
  font-size:14px;
  user-select:none;
  cursor:default;
}

/* ═══════════════════════════════════════════
   ANIMATED BACKGROUND
═══════════════════════════════════════════ */
#os-bg {
  position:fixed; inset:0; z-index:0;
  background:
    radial-gradient(ellipse 80% 60% at 20% 10%, rgba(0,80,180,0.12) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 90%, rgba(200,168,75,0.08) 0%, transparent 55%),
    radial-gradient(ellipse 100% 100% at 50% 50%, #04070f 0%, #020408 100%);
}
#os-bg canvas { position:absolute; inset:0; opacity:0.35; }

/* Scanlines */
#os-bg::after {
  content:'';
  position:absolute; inset:0;
  background:repeating-linear-gradient(
    0deg, transparent, transparent 3px,
    rgba(0,212,255,0.008) 3px, rgba(0,212,255,0.008) 4px
  );
  pointer-events:none;
}

/* ═══════════════════════════════════════════
   BOOT SCREEN
═══════════════════════════════════════════ */
#boot-screen {
  position:fixed; inset:0; z-index:9000;
  background:#000;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  gap:0;
}
.boot-logo {
  font-family:'Orbitron', monospace;
  font-size:clamp(2rem, 6vw, 4rem);
  font-weight:900;
  letter-spacing:0.18em;
  color:var(--gold);
  text-shadow: 0 0 40px var(--gold-glow), 0 0 80px rgba(200,168,75,0.1);
  opacity:0;
  animation: bootLogoIn 1.2s 0.3s ease forwards;
}
.boot-sub {
  font-family:'Exo 2', sans-serif;
  font-size:0.85rem;
  letter-spacing:0.4em;
  color:var(--dim);
  text-transform:uppercase;
  margin-top:0.6rem;
  opacity:0;
  animation: bootLogoIn 1s 1s ease forwards;
}
.boot-bar-wrap {
  width:280px; height:2px;
  background:rgba(255,255,255,0.06);
  margin-top:2.5rem;
  overflow:hidden;
  opacity:0;
  animation: bootLogoIn 0.5s 1.4s ease forwards;
}
.boot-bar {
  height:100%;
  width:0%;
  background:linear-gradient(90deg, var(--cyan), var(--gold));
  box-shadow:0 0 8px var(--cyan);
  animation: bootProgress 2s 1.5s ease forwards;
}
.boot-status {
  font-family:'Orbitron', monospace;
  font-size:0.6rem;
  color:var(--dim);
  letter-spacing:0.2em;
  margin-top:0.8rem;
  opacity:0;
  animation: bootLogoIn 0.5s 1.6s ease forwards;
}
.boot-status span {
  color:var(--cyan);
  animation:blink 0.8s step-end infinite;
}
@keyframes bootLogoIn { to { opacity:1; } }
@keyframes bootProgress { to { width:100%; } }
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

/* ═══════════════════════════════════════════
   LOGIN SCREEN
═══════════════════════════════════════════ */
#login-screen {
  position:fixed; inset:0; z-index:8000;
  display:none;
  align-items:center; justify-content:center;
  flex-direction:column;
}
.login-time {
  font-family:'Orbitron', monospace;
  font-size:clamp(3rem, 10vw, 6rem);
  font-weight:700;
  color:rgba(255,255,255,0.9);
  text-align:center;
  text-shadow:0 2px 30px rgba(0,0,0,0.5);
  letter-spacing:0.06em;
  margin-bottom:0.3rem;
}
.login-date {
  font-family:'Exo 2', sans-serif;
  font-size:1rem;
  color:rgba(255,255,255,0.4);
  letter-spacing:0.3em;
  text-align:center;
  margin-bottom:2.5rem;
  text-transform:uppercase;
}
.login-box {
  background:rgba(255,255,255,0.05);
  backdrop-filter:blur(24px) saturate(1.5);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:16px;
  padding:2rem 2.5rem;
  width:100%; max-width:340px;
  box-shadow:0 24px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04);
}
.login-avatar {
  width:64px; height:64px;
  border-radius:50%;
  background:linear-gradient(135deg, var(--cyan), var(--gold));
  display:flex; align-items:center; justify-content:center;
  font-family:'Orbitron', monospace;
  font-size:1.5rem; font-weight:900;
  color:#000;
  margin:0 auto 1rem;
  box-shadow:0 0 20px var(--cyan-glow);
}
.login-username {
  font-family:'Orbitron', monospace;
  font-size:0.85rem;
  font-weight:600;
  text-align:center;
  letter-spacing:0.15em;
  color:var(--text);
  margin-bottom:1.2rem;
}
.login-input {
  width:100%;
  background:rgba(0,0,0,0.4);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:8px;
  color:var(--text);
  font-family:'Rajdhani', sans-serif;
  font-size:1rem;
  padding:0.65rem 1rem;
  outline:none;
  text-align:center;
  letter-spacing:0.15em;
  transition:border-color 0.2s, box-shadow 0.2s;
}
.login-input:focus {
  border-color:rgba(0,212,255,0.5);
  box-shadow:0 0 12px rgba(0,212,255,0.15);
}
.login-btn {
  width:100%;
  margin-top:0.9rem;
  padding:0.7rem;
  border-radius:8px;
  border:none;
  background:linear-gradient(135deg, var(--cyan), rgba(0,100,200,0.8));
  color:#000;
  font-family:'Orbitron', monospace;
  font-size:0.72rem;
  font-weight:700;
  letter-spacing:0.2em;
  text-transform:uppercase;
  cursor:pointer;
  transition:all 0.2s;
  box-shadow:0 4px 16px var(--cyan-glow);
}
.login-btn:hover { opacity:0.9; transform:translateY(-1px); }
.login-err {
  font-size:0.75rem;
  color:var(--red);
  text-align:center;
  margin-top:0.6rem;
  min-height:1.1em;
  letter-spacing:0.05em;
}
.login-hint {
  font-size:0.7rem;
  color:var(--dim);
  text-align:center;
  margin-top:0.5rem;
  letter-spacing:0.05em;
}

/* ═══════════════════════════════════════════
   DESKTOP
═══════════════════════════════════════════ */
#desktop {
  position:fixed; inset:0;
  z-index:100;
  display:none;
  flex-direction:column;
  overflow:hidden;
}

/* ── TASKBAR ── */
#taskbar {
  position:absolute;
  bottom:0; left:0; right:0;
  height:var(--taskbar-h);
  background:rgba(6,10,20,0.85);
  backdrop-filter:blur(30px) saturate(1.8);
  border-top:1px solid var(--border);
  display:flex; align-items:center;
  padding:0 0.8rem;
  gap:0.5rem;
  z-index:200;
  box-shadow:0 -8px 32px rgba(0,0,0,0.4);
}
.taskbar-start {
  display:flex; align-items:center; gap:0.5rem;
  padding:0.3rem 0.8rem;
  border-radius:6px;
  background:linear-gradient(135deg, rgba(200,168,75,0.15), rgba(0,212,255,0.08));
  border:1px solid rgba(200,168,75,0.25);
  cursor:pointer;
  transition:all 0.2s;
  flex-shrink:0;
}
.taskbar-start:hover {
  background:linear-gradient(135deg, rgba(200,168,75,0.25), rgba(0,212,255,0.15));
  box-shadow:0 0 12px var(--gold-glow);
}
.taskbar-start span:first-child {
  font-family:'Orbitron', monospace;
  font-size:0.75rem;
  font-weight:900;
  color:var(--gold);
  letter-spacing:0.12em;
}
.taskbar-apps {
  flex:1;
  display:flex; align-items:center; gap:4px;
  overflow-x:auto; overflow-y:hidden;
  padding:0 0.3rem;
}
.taskbar-apps::-webkit-scrollbar { display:none; }
.tb-app {
  display:flex; align-items:center; gap:0.4rem;
  padding:0.3rem 0.7rem;
  border-radius:6px;
  cursor:pointer;
  font-size:0.75rem;
  font-weight:500;
  color:var(--dim);
  white-space:nowrap;
  transition:all 0.15s;
  border:1px solid transparent;
  position:relative;
}
.tb-app.open {
  color:var(--text);
  background:rgba(255,255,255,0.07);
  border-color:var(--border);
}
.tb-app.open::after {
  content:'';
  position:absolute; bottom:-2px; left:50%; transform:translateX(-50%);
  width:18px; height:2px;
  background:var(--cyan);
  border-radius:2px;
  box-shadow:0 0 6px var(--cyan);
}
.tb-app:hover { color:var(--text); background:rgba(255,255,255,0.05); }
.taskbar-right {
  display:flex; align-items:center; gap:0.8rem;
  padding-left:0.8rem;
  border-left:1px solid var(--border);
  flex-shrink:0;
}
.tb-clock {
  font-family:'Orbitron', monospace;
  font-size:0.7rem;
  color:var(--text);
  text-align:right;
  line-height:1.4;
  letter-spacing:0.08em;
}
.tb-clock .tb-date { font-size:0.6rem; color:var(--dim); }
.tb-icon {
  font-size:1rem; cursor:pointer;
  opacity:0.6; transition:opacity 0.15s;
}
.tb-icon:hover { opacity:1; }

/* ── WORKSPACE (above taskbar) ── */
#workspace {
  position:absolute;
  top:0; left:0; right:0;
  bottom:var(--taskbar-h);
  overflow:hidden;
}

/* ── DESKTOP ICONS ── */
#icon-grid {
  position:absolute;
  top:1.5rem; left:1.5rem;
  display:flex; flex-direction:column;
  gap:0.8rem;
  z-index:110;
}
.desk-icon {
  display:flex; flex-direction:column;
  align-items:center; gap:0.3rem;
  width:72px; cursor:pointer;
  padding:0.5rem;
  border-radius:10px;
  border:1px solid transparent;
  transition:all 0.2s;
}
.desk-icon:hover {
  background:rgba(255,255,255,0.06);
  border-color:var(--border);
}
.desk-icon.selected {
  background:rgba(0,212,255,0.1);
  border-color:rgba(0,212,255,0.3);
}
.icon-emoji { font-size:2rem; line-height:1; }
.icon-label {
  font-size:0.65rem; font-weight:600;
  color:var(--text); text-align:center;
  letter-spacing:0.04em; line-height:1.3;
  text-shadow:0 1px 4px rgba(0,0,0,0.9);
  word-break:break-word;
}

/* ── WINDOWS ── */
.os-window {
  position:absolute;
  background:var(--glass);
  backdrop-filter:blur(32px) saturate(1.6);
  border:1px solid var(--border);
  border-radius:var(--radius);
  box-shadow:
    0 32px 80px rgba(0,0,0,0.7),
    0 0 0 1px rgba(255,255,255,0.04),
    inset 0 1px 0 rgba(255,255,255,0.06);
  overflow:hidden;
  display:flex; flex-direction:column;
  min-width:340px; min-height:240px;
  transition:box-shadow 0.2s, opacity 0.15s;
  z-index:150;
}
.os-window.focused {
  box-shadow:
    0 40px 100px rgba(0,0,0,0.8),
    0 0 0 1px rgba(0,212,255,0.15),
    inset 0 1px 0 rgba(255,255,255,0.08);
  border-color:rgba(0,212,255,0.18);
}
.os-window.minimized { display:none; }
.os-window.maximized {
  top:0!important; left:0!important;
  width:100%!important; height:100%!important;
  border-radius:0; border:none;
}

/* Title bar */
.win-titlebar {
  display:flex; align-items:center;
  padding:0 0.8rem;
  height:36px;
  background:rgba(0,0,0,0.25);
  border-bottom:1px solid var(--border);
  cursor:move;
  flex-shrink:0;
  gap:0.5rem;
}
.win-controls {
  display:flex; gap:6px;
  flex-shrink:0;
}
.win-btn {
  width:12px; height:12px;
  border-radius:50%;
  border:none; cursor:pointer;
  transition:filter 0.15s;
  flex-shrink:0;
}
.win-btn:hover { filter:brightness(1.4); }
.win-btn.close { background:#ff5f57; }
.win-btn.min { background:#febc2e; }
.win-btn.max { background:#28c840; }
.win-title {
  flex:1;
  font-family:'Orbitron', monospace;
  font-size:0.65rem;
  font-weight:600;
  letter-spacing:0.15em;
  color:var(--dim);
  text-align:center;
  text-transform:uppercase;
  truncate:ellipsis;
  white-space:nowrap;
  overflow:hidden;
}
.win-icon { font-size:0.9rem; }

/* Window body */
.win-body {
  flex:1; overflow:hidden;
  position:relative;
}
.win-body iframe {
  width:100%; height:100%;
  border:none;
  display:block;
}
/* Loading state */
.win-loading {
  position:absolute; inset:0;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  gap:0.8rem;
  background:var(--glass);
}
.win-loading-spinner {
  width:32px; height:32px;
  border:2px solid var(--border);
  border-top-color:var(--cyan);
  border-radius:50%;
  animation:spin 0.7s linear infinite;
}
.win-loading-text {
  font-family:'Orbitron', monospace;
  font-size:0.6rem;
  color:var(--dim);
  letter-spacing:0.2em;
}
@keyframes spin { to { transform:rotate(360deg); } }

/* Resize handle */
.win-resize {
  position:absolute; bottom:0; right:0;
  width:16px; height:16px;
  cursor:se-resize;
  opacity:0.3;
}
.win-resize::after {
  content:'';
  position:absolute; bottom:3px; right:3px;
  width:8px; height:8px;
  border-right:2px solid var(--dim);
  border-bottom:2px solid var(--dim);
}

/* ── NOTIFICATION ── */
.os-notif {
  position:fixed;
  top:1rem; right:1rem;
  z-index:9000;
  background:rgba(10,16,30,0.95);
  backdrop-filter:blur(20px);
  border:1px solid var(--border);
  border-radius:10px;
  padding:0.8rem 1.1rem;
  min-width:260px; max-width:320px;
  box-shadow:0 12px 40px rgba(0,0,0,0.5);
  display:flex; gap:0.8rem; align-items:flex-start;
  animation:notifIn 0.3s ease;
  border-left:3px solid var(--cyan);
}
.os-notif.warn { border-left-color:var(--gold); }
.os-notif.err { border-left-color:var(--red); }
.notif-icon { font-size:1.3rem; flex-shrink:0; }
.notif-content { flex:1; }
.notif-title {
  font-size:0.78rem; font-weight:700;
  color:var(--text); margin-bottom:0.2rem;
}
.notif-msg { font-size:0.72rem; color:var(--dim); line-height:1.5; }
@keyframes notifIn {
  from { transform:translateX(110%); opacity:0; }
  to   { transform:none; opacity:1; }
}

/* ── RIGHT-CLICK MENU ── */
#ctx-menu {
  position:fixed;
  z-index:9999;
  background:rgba(10,16,30,0.95);
  backdrop-filter:blur(20px);
  border:1px solid var(--border);
  border-radius:8px;
  padding:0.3rem;
  min-width:180px;
  box-shadow:0 12px 40px rgba(0,0,0,0.6);
  display:none;
}
.ctx-item {
  padding:0.45rem 0.9rem;
  border-radius:5px;
  font-size:0.8rem;
  cursor:pointer;
  color:var(--text);
  display:flex; align-items:center; gap:0.6rem;
  transition:background 0.1s;
}
.ctx-item:hover { background:rgba(255,255,255,0.07); }
.ctx-sep { height:1px; background:var(--border); margin:0.3rem 0; }

/* ── START MENU ── */
#start-menu {
  position:fixed;
  bottom:calc(var(--taskbar-h) + 6px);
  left:0.8rem;
  width:320px;
  background:rgba(8,12,22,0.96);
  backdrop-filter:blur(40px) saturate(2);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:12px;
  box-shadow:0 -24px 60px rgba(0,0,0,0.7);
  z-index:8000;
  display:none;
  overflow:hidden;
  animation:startIn 0.2s ease;
}
@keyframes startIn {
  from { transform:translateY(10px) scale(0.97); opacity:0; }
  to   { transform:none; opacity:1; }
}
.start-header {
  padding:1.2rem 1rem 0.8rem;
  border-bottom:1px solid var(--border);
  display:flex; align-items:center; gap:0.8rem;
}
.start-avatar {
  width:40px; height:40px; border-radius:50%;
  background:linear-gradient(135deg,var(--cyan),var(--gold));
  display:flex; align-items:center; justify-content:center;
  font-family:'Orbitron',monospace; font-size:1rem; font-weight:900; color:#000;
  box-shadow:0 0 12px var(--cyan-glow);
}
.start-user { font-weight:700; font-size:0.9rem; }
.start-role { font-size:0.68rem; color:var(--gold); letter-spacing:0.1em; }
.start-apps {
  padding:0.6rem;
  display:grid; grid-template-columns:1fr 1fr;
  gap:4px;
}
.start-app {
  display:flex; align-items:center; gap:0.6rem;
  padding:0.55rem 0.7rem; border-radius:7px;
  cursor:pointer; transition:background 0.15s;
  font-size:0.8rem; font-weight:500; color:var(--text);
}
.start-app:hover { background:rgba(255,255,255,0.07); }
.start-app-icon { font-size:1.2rem; }
.start-footer {
  border-top:1px solid var(--border);
  padding:0.6rem;
  display:flex; justify-content:space-between;
}
.start-action {
  display:flex; align-items:center; gap:0.4rem;
  padding:0.4rem 0.7rem; border-radius:6px;
  cursor:pointer; font-size:0.75rem; color:var(--dim);
  transition:all 0.15s;
}
.start-action:hover { background:rgba(255,255,255,0.07); color:var(--text); }

/* ── SECURITY LAYER ── */
#security-overlay {
  position:fixed; inset:0; z-index:99999;
  background:#000;
  display:none;
  flex-direction:column;
  align-items:center; justify-content:center;
  gap:1rem;
}
.sec-warning {
  font-family:'Orbitron', monospace;
  font-size:1.2rem; font-weight:900;
  color:var(--red);
  letter-spacing:0.1em;
  text-align:center;
  animation:secPulse 0.5s ease infinite alternate;
}
@keyframes secPulse { from{opacity:1;} to{opacity:0.4;} }
.sec-msg { font-size:0.8rem; color:var(--dim); text-align:center; max-width:400px; line-height:1.8; }

/* ── WALLPAPER PICKER (subtle) ── */
.wallpaper-1 { background: radial-gradient(ellipse 80% 60% at 20% 10%, rgba(0,80,180,0.18) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 80% 90%, rgba(200,168,75,0.1) 0%, transparent 55%), #04070f; }
.wallpaper-2 { background: radial-gradient(ellipse 100% 80% at 50% 0%, rgba(0,100,60,0.2) 0%, transparent 60%), #040d08; }
.wallpaper-3 { background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(80,0,160,0.2) 0%, transparent 65%), #07040f; }

/* Misc */
.no-select { user-select:none; }
::-webkit-scrollbar { width:4px; height:4px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.1); border-radius:4px; }
</style>
</head>
<body>

<!-- ═══════ BACKGROUND ═══════ -->
<div id="os-bg">
  <canvas id="bg-canvas"></canvas>
</div>

<!-- ═══════ BOOT SCREEN ═══════ -->
<div id="boot-screen">
  <div class="boot-logo">JecksOS</div>
  <div class="boot-sub">Powered by BEAST Engine · v1.0</div>
  <div class="boot-bar-wrap">
    <div class="boot-bar"></div>
  </div>
  <div class="boot-status">Initializing secure kernel<span>_</span></div>
</div>

<!-- ═══════ LOGIN SCREEN ═══════ -->
<div id="login-screen">
  <div class="login-time" id="login-time">00:00</div>
  <div class="login-date" id="login-date">—</div>
  <div class="login-box">
    <div class="login-avatar" id="login-avatar">J</div>
    <div class="login-username">JECKSTOM · ADMIN</div>
    <input class="login-input" type="password" id="login-pass"
