// ═══════════════════════════════════════════════
//  MENUS & NOTIFICATIONS
// ═══════════════════════════════════════════════
function toggleStartMenu() {
  const m = document.getElementById('start-menu');
  m.style.display = m.style.display === 'block' ? 'none' : 'block';
}
function closeStartMenu() {
  document.getElementById('start-menu').style.display = 'none';
}

function showCtxMenu(x, y) {
  const m = document.getElementById('ctx-menu');
  m.style.display = 'block';
  m.style.left = Math.min(x, window.innerWidth - 200) + 'px';
  m.style.top  = Math.min(y, window.innerHeight - 180) + 'px';
}
function hideCtxMenu() {
  document.getElementById('ctx-menu').style.display = 'none';
}

function ctxAction(action) {
  hideCtxMenu();
  if (action === 'settings') openApp('settings');
  else if (action === 'about') openApp('about');
  else if (action === 'wallpaper') { openApp('settings'); }
  else if (action === 'refresh') {
    pushNotif('Desktop', 'Desktop refreshed.', 'info');
    buildIconGrid();
  }
}

function showSettings() { openApp('settings'); closeStartMenu(); }

document.addEventListener('click', e => {
  hideCtxMenu();
  if (!e.target.closest('#start-menu') && !e.target.closest('.taskbar-start')) closeStartMenu();
  if (!e.target.closest('.desk-icon')) document.querySelectorAll('.desk-icon').forEach(d => d.classList.remove('selected'));
});

// Notifications
let notifQueue = [];
function pushNotif(title, msg, type = 'info') {
  const n = document.createElement('div');
  n.className = 'os-notif' + (type === 'warn' ? ' warn' : type === 'err' ? ' err' : '');
  n.innerHTML = `<div class="notif-icon">${type==='warn'?'⚠️':type==='err'?'🚨':'💠'}</div>
    <div class="notif-content"><div class="notif-title">${title}</div><div class="notif-msg">${msg}</div></div>`;
  n.style.cssText += `top:${1 + notifQueue.length * 5.5}rem`;
  document.body.appendChild(n);
  notifQueue.push(n);
  setTimeout(() => {
    n.style.opacity = '0'; n.style.transform = 'translateX(110%)'; n.style.transition = 'all 0.4s';
    setTimeout(() => { n.remove(); notifQueue = notifQueue.filter(x => x !== n); }, 400);
  }, 4000);
}

function showSecurityAlert(msg) {
  document.getElementById('sec-msg').textContent = msg;
  document.getElementById('security-overlay').style.display = 'flex';
}

