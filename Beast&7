<script>
// ═══════════════════════════════════════════════
//  JecksOS KERNEL
// ═══════════════════════════════════════════════

// ── SECURITY ──
// Password stored as hash (djb2). Default: jecks7
// Change via Settings window
const OS_PASS_KEY = 'jecksOS_passHash';
const OS_SETTINGS_KEY = 'jecksOS_settings';

function djb2Hash(s) {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h) ^ s.charCodeAt(i);
  return (h >>> 0).toString(16);
}

function getPassHash() {
  return localStorage.getItem(OS_PASS_KEY) || djb2Hash('jecks7');
}

// Anti-tamper: detect devtools open (basic indicator)
let devtoolsOpen = false;
const dtCheck = setInterval(() => {
  const t = performance.now();
  debugger;
  if (performance.now() - t > 100) {
    if (!devtoolsOpen) {
      devtoolsOpen = true;
      document.getElementById('sec-icon').textContent = '⚠️';
      pushNotif('Security', 'Developer tools detected. Activity logged.', 'warn');
    }
  } else {
    devtoolsOpen = false;
    document.getElementById('sec-icon').textContent = '🔒';
  }
}, 3000);

// Disable right-click outside OS context menu
document.addEventListener('contextmenu', e => {
  e.preventDefault();
  showCtxMenu(e.clientX, e.clientY);
});

// ── APP REGISTRY ──
const APPS = [
  { id:'prime',    name:'Prime Security',   icon:'🔐', sub:'512-bit RSA Engine',       file:'prime-security-suite.html',    w:820, h:580 },
  { id:'soul',     name:'Soul Mirror',      icon:'✦',  sub:'Biblical Identity Engine', file:'soul-mirror.html',             w:860, h:600 },
  { id:'games',    name:'Game Suite',       icon:'🎮', sub:'Archery & Brick Breaker',  file:'game-suite.html',              w:660, h:580 },
  { id:'div7',     name:'Div Test of 7',   icon:'⬡',  sub:'Prime Encoder OS Module',  file:'divisibility-test-of-7.html',  w:900, h:600 },
  { id:'comms',    name:'BEAST Comms',      icon:'💬', sub:'Communication + Payment',  file:'beast-os-comms.html',          w:820, h:580 },
  { id:'settings', name:'Settings',         icon:'⚙',  sub:'JecksOS Configuration',    file:null,                           w:500, h:400 },
  { id:'terminal', name:'Terminal',         icon:'⌨',  sub:'System Terminal',          file:null,                           w:560, h:380 },
  { id:'about',    name:'About JecksOS',    icon:'★',  sub:'System Information',       file:null,                           w:460, h:360 },
];

// ── WINDOW MANAGER ──
let windows = {};
let zTop = 200;
let activeWin = null;

// ── OS STATE ──
let osSettings = JSON.parse(localStorage.getItem(OS_SETTINGS_KEY) || '{"wallpaper":0,"sound":true}');

// ═══════════════════════════════════════════════
//  BOOT SEQUENCE
// ═══════════════════════════════════════════════
window.addEventListener('load', () => {
  startBgCanvas();
  updateClock();
  setInterval(updateClock, 1000);

  // Boot → Login after ~3.8s
  setTimeout(() => {
    document.getElementById('boot-screen').style.display = 'none';
    const ls = document.getElementById('login-screen');
    ls.style.display = 'flex';
    document.getElementById('login-pass').focus();
  }, 3800);
});

// ═══════════════════════════════════════════════
//  LOGIN
// ═══════════════════════════════════════════════
function loginOS() {
  const pass = document.getElementById('login-pass').value;
  const err = document.getElementById('login-err');
  if (!pass) { err.textContent = 'Enter your passcode.'; return; }

  if (djb2Hash(pass) !== getPassHash()) {
    err.textContent = 'Incorrect passcode. Access denied.';
    document.getElementById('login-pass').value = '';
    // Log failed attempt
    const fails = parseInt(localStorage.getItem('jecksOS_fails') || '0') + 1;
    localStorage.setItem('jecksOS_fails', fails);
    if (fails >= 5) {
      showSecurityAlert('Brute force attempt: ' + fails + ' failed logins recorded.');
    }
    return;
  }

  localStorage.setItem('jecksOS_fails', '0');
  document.getElementById('login-screen').style.display = 'none';
  launchDesktop();
}

function lockOS() {
  closeStartMenu();
  // Close all windows
  Object.keys(windows).forEach(id => destroyWindow(id));
  document.getElementById('desktop').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('login-pass').value = '';
  document.getElementById('login-pass').focus();
}

function shutdownOS() {
  closeStartMenu();
  document.getElementById('desktop').style.display = 'none';
  document.getElementById('boot-screen').style.display = 'flex';
  document.getElementById('boot-screen').style.flexDirection = 'column';
  document.getElementById('boot-screen').innerHTML = `
    <div style="font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;color:var(--gold);letter-spacing:0.15em">JecksOS</div>
    <div style="font-family:'Exo 2',sans-serif;font-size:0.8rem;color:var(--dim);letter-spacing:0.3em;margin-top:0.5rem">Shutting down safely...</div>
    <div style="margin-top:2rem;font-family:'Orbitron',monospace;font-size:0.65rem;color:var(--dim);letter-spacing:0.2em">All sessions saved · Goodbye, Jeckstom</div>`;
}

// ═══════════════════════════════════════════════
//  DESKTOP INIT
// ═══════════════════════════════════════════════
function launchDesktop() {
  const desktop = document.getElementById('desktop');
  desktop.style.display = 'flex';
  buildIconGrid();
  buildStartMenu();
  pushNotif('JecksOS', 'Welcome back, Jeckstom. System secure.', 'info');
}

function buildIconGrid() {
  const grid = document.getElementById('icon-grid');
  grid.innerHTML = '';
  APPS.forEach(app => {
    const el = document.createElement('div');
    el.className = 'desk-icon';
    el.innerHTML = `<div class="icon-emoji">${app.icon}</div><div class="icon-label">${app.name}</div>`;
    el.addEventListener('dblclick', () => openApp(app.id));
    el.addEventListener('click', e => {
      document.querySelectorAll('.desk-icon').forEach(d => d.classList.remove('selected'));
      el.classList.add('selected');
      e.stopPropagation();
    });
    grid.appendChild(el);
  });
}

function buildStartMenu() {
  const list = document.getElementById('start-apps-list');
  list.innerHTML = '';
  APPS.forEach(app => {
    const el = document.createElement('div');
    el.className = 'start-app';
    el.innerHTML = `<span class="start-app-icon">${app.icon}</span><span>${app.name}</span>`;
    el.addEventListener('click', () => { openApp(app.id); closeStartMenu(); });
    list.appendChild(el);
  });
}

// ═══════════════════════════════════════════════
//  WINDOW MANAGER
// ═══════════════════════════════════════════════
function openApp(id) {
  // If already open, focus it
  if (windows[id]) {
    focusWindow(id);
    if (windows[id].minimized) unminimizeWindow(id);
    return;
  }
  const app = APPS.find(a => a.id === id);
  if (!app) return;
  createWindow(app);
}

function createWindow(app) {
  const container = document.getElementById('windows-container');
  const win = document.createElement('div');
  win.className = 'os-window';
  win.id = 'win-' + app.id;
  win.style.pointerEvents = 'all';

  // Position: stagger new windows
  const offset = Object.keys(windows).length * 30;
  const maxLeft = window.innerWidth - app.w - 40;
  const maxTop = window.innerHeight - app.h - 80;
  win.style.left = Math.min(80 + offset, maxLeft) + 'px';
  win.style.top = Math.min(40 + offset, maxTop) + 'px';
  win.style.width = app.w + 'px';
  win.style.height = app.h + 'px';
  win.style.zIndex = ++zTop;

  // Build interior
  win.innerHTML = `
    <div class="win-titlebar" id="tb-${app.id}">
      <div class="win-controls">
        <button class="win-btn close" onclick="destroyWindow('${app.id}')"></button>
        <button class="win-btn min" onclick="minimizeWindow('${app.id}')"></button>
        <button class="win-btn max" onclick="toggleMaximize('${app.id}')"></button>
      </div>
      <div class="win-title"><span class="win-icon">${app.icon}</span>  ${app.name}</div>
      <div style="width:54px"></div>
    </div>
    <div class="win-body" id="body-${app.id}">
      ${app.file
        ? `<div class="win-loading" id="loading-${app.id}">
             <div class="win-loading-spinner"></div>
             <div class="win-loading-text">Loading ${app.name}...</div>
           </div>
           <iframe src="${app.file}" id="iframe-${app.id}"
             style="opacity:0;transition:opacity 0.3s"
             onload="iframeLoaded('${app.id}')"></iframe>`
        : `<div id="builtin-${app.id}" style="height:100%;overflow-y:auto;padding:1.2rem"></div>`
      }
    </div>
    <div class="win-resize" id="resize-${app.id}"></div>`;

  container.appendChild(win);
  windows[app.id] = { el: win, minimized: false, maximized: false, app };

  // Built-in apps (no iframe)
  if (!app.file) renderBuiltin(app.id);

  makeDraggable(win, document.getElementById('tb-' + app.id));
  makeResizable(win, document.getElementById('resize-' + app.id));
  win.addEventListener('mousedown', () => focusWindow(app.id));

  addTaskbarBtn(app);
  focusWindow(app.id);
}

function iframeLoaded(id) {
  const loading = document.getElementById('loading-' + id);
  const iframe = document.getElementById('iframe-' + id);
  if (loading) loading.remove();
  if (iframe) iframe.style.opacity = '1';
}

function focusWindow(id) {
  if (activeWin) {
    const prev = document.getElementById('win-' + activeWin);
    if (prev) prev.classList.remove('focused');
  }
  const win = document.getElementById('win-' + id);
  if (win) {
    win.style.zIndex = ++zTop;
    win.classList.add('focused');
  }
  activeWin = id;
  updateTaskbarActive(id);
}

function minimizeWindow(id) {
  const win = document.getElementById('win-' + id);
  if (win) win.classList.add('minimized');
  windows[id].minimized = true;
  updateTaskbarActive(null);
}

function unminimizeWindow(id) {
  const win = document.getElementById('win-' + id);
  if (win) win.classList.remove('minimized');
  windows[id].minimized = false;
  focusWindow(id);
}

function toggleMaximize(id) {
  const win = document.getElementById('win-' + id);
  if (!win) return;
  if (windows[id].maximized) {
    win.classList.remove('maximized');
    win.style.left = windows[id]._prev.left;
    win.style.top = windows[id]._prev.top;
    win.style.width = windows[id]._prev.w;
    win.style.height = windows[id]._prev.h;
    windows[id].maximized = false;
  } else {
    windows[id]._prev = { left: win.style.left, top: win.style.top, w: win.style.width, h: win.style.height };
    win.classList.add('maximized');
    windows[id].maximized = true;
  }
}

function destroyWindow(id) {
  const win = document.getElementById('win-' + id);
  if (win) win.remove();
  delete windows[id];
  removeTaskbarBtn(id);
  if (activeWin === id) activeWin = null;
}

// ── TASKBAR ──
function addTaskbarBtn(app) {
  const bar = document.getElementById('taskbar-apps');
  const btn = document.createElement('div');
  btn.className = 'tb-app open';
  btn.id = 'tbapp-' + app.id;
  btn.innerHTML = `${app.icon} ${app.name}`;
  btn.addEventListener('click', () => {
    if (windows[app.id]?.minimized) unminimizeWindow(app.id);
    else if (activeWin === app.id) minimizeWindow(app.id);
    else focusWindow(app.id);
  });
  bar.appendChild(btn);
}

function removeTaskbarBtn(id) {
  document.getElementById('tbapp-' + id)?.remove();
}

function updateTaskbarActive(id) {
  document.querySelectorAll('.tb-app').forEach(b => b.style.opacity = '0.7');
  if (id) {
    const btn = document.getElementById('tbapp-' + id);
    if (btn) btn.style.opacity = '1';
  }
}

// ═══════════════════════════════════════════════
//  DRAG & RESIZE
// ═══════════════════════════════════════════════
function makeDraggable(win, handle) {
  let dragging = false, ox = 0, oy = 0;
  handle.addEventListener('mousedown', e => {
    if (e.target.classList.contains('win-btn')) return;
    dragging = true;
    ox = e.clientX - win.offsetLeft;
    oy = e.clientY - win.offsetTop;
    document.body.style.cursor = 'move';
    e.preventDefault();
  });
  document.addEventListener('mousemove', e => {
    if (!dragging) return;
    let nx = e.clientX - ox;
    let ny = e.clientY - oy;
    nx = Math.max(0, Math.min(window.innerWidth - win.offsetWidth, nx));
    ny = Math.max(0, Math.min(window.innerHeight - win.offsetHeight - 48, ny));
    win.style.left = nx + 'px';
    win.style.top  = ny + 'px';
  });
  document.addEventListener('mouseup', () => {
    dragging = false;
    document.body.style.cursor = '';
  });
}

function makeResizable(win, handle) {
  let resizing = false, startX, startY, startW, startH;
  handle.addEventListener('mousedown', e => {
    resizing = true;
    startX = e.clientX; startY = e.clientY;
    startW = win.offsetWidth; startH = win.offsetHeight;
    e.preventDefault(); e.stopPropagation();
  });
  document.addEventListener('mousemove', e => {
    if (!resizing) return;
    const nw = Math.max(340, startW + e.clientX - startX);
    const nh = Math.max(240, startH + e.clientY - startY);
    win.style.width  = nw + 'px';
    win.style.height = nh + 'px';
  });
  document.addEventListener('mouseup', () => { resizing = false; });
}

// ═══════════════════════════════════════════════
//  BUILT-IN APPS (Settings, Terminal, About)
// ═══════════════════════════════════════════════
function renderBuiltin(id) {
  const el = document.getElementById('builtin-' + id);
  if (!el) return;
  if (id === 'settings') renderSettings(el);
  else if (id === 'terminal') renderTerminal(el);
  else if (id === 'about') renderAbout(el);
}

function renderSettings(el) {
  el.innerHTML = `
  <div style="font-family:'Orbitron',monospace;font-size:0.7rem;color:var(--gold);letter-spacing:0.18em;margin-bottom:1.2rem">⚙ SYSTEM SETTINGS</div>

  <div style="margin-bottom:1.2rem;padding:1rem;background:rgba(0,0,0,0.3);border-radius:8px;border:1px solid var(--border)">
    <div style="font-size:0.72rem;font-weight:700;color:var(--dim);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.8rem">Security</div>
    <div style="font-size:0.82rem;margin-bottom:0.5rem">Change OS Passcode</div>
    <input id="s-old" type="password" placeholder="Current passcode" style="width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--border);color:var(--text);padding:0.5rem 0.7rem;border-radius:6px;margin-bottom:0.4rem;font-family:'Rajdhani',sans-serif;font-size:0.9rem;outline:none"/>
