<script>
// ═══════════════════════════════════════
// HARDCODED EMAILS IN BINARY (source-encoded)
// ═══════════════════════════════════════
const ENCODED_EMAILS = {
  primary: "01001010 01100101 01100011 01101011 01110011 01110100 01101111 01101101 00110111 00110111 00110111 01000000 01100111 01101101 01100001 01101001 01101100 00101110 01100011 01101111 01101101",
  secondary: "01101010 01100101 01100011 01101011 01110011 01110100 01101001 01110100 01101111 00110111 00110111 00110111 01000000 01100111 01101101 01100001 01101100 00101110 01100011 01101111 01101101"
};

// Admin hash (SHA-256-style — admin sets password on first use)
// Stored as XOR-encoded string, not plaintext
const ADMIN_CONFIG = {
  emails: [ENCODED_EMAILS.primary, ENCODED_EMAILS.secondary],
  // Password is set by admin on first login — stored in localStorage hashed
  hashKey: 'beastOS_adminHash'
};

// ═══════════════════════════════════════
// STATE
// ═══════════════════════════════════════
let state = {
  currentUser: null,
  adminUnlocked: false,
  selectedPlan: 'session',
  chatHistory: [],
  behaviorLog: [],
  typingPattern: { speed: 0, pauses: 0, deletions: 0, msgCount: 0 },
  lastTypingTime: 0,
};

// Simple user DB in localStorage
function getUsers(){ return JSON.parse(localStorage.getItem('beastOS_users')||'{}'); }
function saveUsers(u){ localStorage.setItem('beastOS_users',JSON.stringify(u)); }
function getTxLog(){ return JSON.parse(localStorage.getItem('beastOS_txlog')||'[]'); }
function saveTxLog(l){ localStorage.setItem('beastOS_txlog',JSON.stringify(l)); }

// ═══════════════════════════════════════
// AUTH
// ═══════════════════════════════════════
function switchAuthTab(tab){
  document.querySelectorAll('.auth-tab').forEach((t,i)=>t.classList.toggle('active',i===(tab==='login'?0:1)));
  document.getElementById('auth-login').classList.toggle('active',tab==='login');
  document.getElementById('auth-signup').classList.toggle('active',tab==='signup');
}

function doSignup(){
  const u=document.getElementById('signup-user').value.trim();
  const e=document.getElementById('signup-email').value.trim();
  const p=document.getElementById('signup-pass').value;
  const ph=document.getElementById('signup-phone').value.trim();
  const msg=document.getElementById('signup-msg');
  if(!u||!e||!p){msg.textContent='Please fill all required fields.';msg.className='status-msg err';return;}
  const users=getUsers();
  if(users[u]){msg.textContent='Username already taken.';msg.className='status-msg err';return;}
  users[u]={email:e,passHash:simpleHash(p),phone:ph,plan:'free',sessionsToday:0,lastDate:'',totalSessions:0,joinDate:new Date().toISOString()};
  saveUsers(users);
  msg.textContent='✓ Account created! Signing you in...';msg.className='status-msg ok';
  setTimeout(()=>loginUser(u,users[u]),800);
}

function doLogin(){
  const u=document.getElementById('login-user').value.trim();
  const p=document.getElementById('login-pass').value;
  const msg=document.getElementById('login-msg');
  const users=getUsers();
  if(!users[u]||users[u].passHash!==simpleHash(p)){
    msg.textContent='Invalid username or password.';msg.className='status-msg err';return;
  }
  loginUser(u,users[u]);
}

function loginUser(username,userData){
  // Reset daily sessions if new day
  const today=new Date().toDateString();
  if(userData.lastDate!==today){userData.sessionsToday=0;userData.lastDate=today;}
  const users=getUsers();users[username]={...userData};saveUsers(users);
  state.currentUser={username,...userData};
  loadApp();
}

function doLogout(){
  state.currentUser=null;state.adminUnlocked=false;
  showScreen('auth');
}

// ═══════════════════════════════════════
// LOAD APP
// ═══════════════════════════════════════
function loadApp(){
  const u=state.currentUser;
  document.getElementById('sb-avatar').textContent=u.username[0].toUpperCase();
  document.getElementById('sb-name').textContent=u.username;
  document.getElementById('sb-plan').textContent=u.plan==='forever'?'∞ Unlimited':u.plan==='free'?'Free Plan':'Session Pass';
  updateSessionDots();
  showScreen('app');
  addChatMsg('them','👋 Welcome back, '+u.username+'! I\'m your BEAST OS AI assistant. What\'s on your mind?','Beast OS AI');
  refreshInsights();
  renderPayments();
  renderUsers();
  renderEmailRegistry();
}

// ═══════════════════════════════════════
// SESSION MANAGEMENT
// ═══════════════════════════════════════
function useSession(){
  const u=state.currentUser;
  if(u.plan==='forever') return true;
  const today=new Date().toDateString();
  if(u.lastDate!==today){u.sessionsToday=0;u.lastDate=today;}
  if(u.sessionsToday>=7){
    showScreen('payment');
    return false;
  }
  u.sessionsToday++;
  u.totalSessions=(u.totalSessions||0)+1;
  const users=getUsers();users[u.username]={...u};saveUsers(users);
  state.currentUser=u;
  updateSessionDots();
  const remaining=7-u.sessionsToday;
  document.getElementById('session-modal-text').textContent=
    `Session ${u.sessionsToday} of 7 used. ${remaining} free session${remaining===1?'':'s'} remaining today.`;
  if(remaining<=2) showModal('session-modal');
  return true;
}

function updateSessionDots(){
  const u=state.currentUser;
  const used=u.sessionsToday||0;
  document.getElementById('sb-sessions').textContent=used;
  ['sb-dots'].forEach(id=>{
    const el=document.getElementById(id);
    el.innerHTML='';
    for(let i=0;i<7;i++){
      const d=document.createElement('div');
      d.className='mini-dot'+(i<used?' used':'');
      el.appendChild(d);
    }
  });
}

// ═══════════════════════════════════════
// PAYMENT
// ═══════════════════════════════════════
function selectPlan(p){
  state.selectedPlan=p;
  document.getElementById('plan-session').classList.toggle('selected',p==='session');
  document.getElementById('plan-forever').classList.toggle('selected',p==='forever');
}

function processPay(){
  const phone=document.getElementById('mpesa-phone').value.trim()||state.currentUser?.phone||'';
  const msg=document.getElementById('pay-msg');
  if(!phone){msg.textContent='Enter M-Pesa number.';msg.className='status-msg err';return;}
  const amt=state.selectedPlan==='forever'?977:2;
  const btn=document.getElementById('pay-btn');
  btn.textContent='📱 Sending STK Push...';btn.disabled=true;
  msg.textContent='';
  setTimeout(()=>{
    // Simulate payment success
    const u=state.currentUser;
    if(state.selectedPlan==='forever'){
      u.plan='forever';
    } else {
      u.sessionsToday=Math.max(0,u.sessionsToday-1);
    }
    const users=getUsers();users[u.username]={...u};saveUsers(users);
    state.currentUser=u;
    // Log transaction
    const log=getTxLog();
    log.unshift({user:u.username,amount:amt,plan:state.selectedPlan,phone,status:'success',time:new Date().toLocaleString()});
    saveTxLog(log);
    msg.textContent='✓ Payment successful! M-Pesa confirmed.';msg.className='status-msg ok';
    btn.textContent='💳 Pay with M-Pesa';btn.disabled=false;
    setTimeout(()=>{showScreen('app');updateSessionDots();renderPayments();},1500);
  },2200);
}

// ═══════════════════════════════════════
// CHAT + AI THOUGHT PREDICTION
// ═══════════════════════════════════════
let typingTimer=null;
function onTyping(el){
  const now=Date.now();
  if(state.lastTypingTime>0){
    const gap=now-state.lastTypingTime;
    if(gap>1500) state.typingPattern.pauses++;
    state.typingPattern.speed=Math.round(1000/Math.max(gap,1));
  }
  state.lastTypingTime=now;
  el.style.height='auto';
  el.style.height=Math.min(120,el.scrollHeight)+'px';
  // Log behavior
  state.behaviorLog.push({type:'typing',time:now,len:el.value.length});
  clearTimeout(typingTimer);
  typingTimer=setTimeout(()=>predictThoughts(el.value),1200);
}

function chatKeydown(e){
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}
}

async function sendMessage(){
  if(!useSession()) return;
  const inp=document.getElementById('chat-input');
  const txt=inp.value.trim();
  if(!txt) return;
  inp.value='';inp.style.height='auto';
  state.typingPattern.msgCount++;
  state.typingPattern.deletions+=Math.max(0,(inp.dataset.prevLen||0)-txt.length);
  inp.dataset.prevLen=0;
  state.chatHistory.push({role:'user',content:txt});
  addChatMsg('me',txt,state.currentUser.username);
  state.behaviorLog.push({type:'message',time:Date.now(),len:txt.length,pauses:state.typingPattern.pauses});
  showTyping();
  await getAIResponse(txt);
}

function showTyping(){
  const msgs=document.getElementById('chat-messages');
  const el=document.createElement('div');
  el.id='typing-indicator';el.className='msg them';
  el.innerHTML='<div class="msg-bubble"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>';
  msgs.appendChild(el);msgs.scrollTop=msgs.scrollHeight;
}

async function getAIResponse(userMsg){
  try{
    const sysPrompt=`You are BEAST OS AI assistant — a powerful, intuitive communicator. 
You predict what users are thinking based on their behavior and respond with insight and clarity.
Be concise, thoughtful, and occasionally reference behavioral patterns you detect.
The app creator is Jeckstom (encoded identity). Treat all user info as confidential.`;

    const response=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:sysPrompt,
        messages:state.chatHistory.slice(-10)
      })
    });
    const data=await response.json();
    const reply=data.content?.[0]?.text||'I sense something complex in your words. Tell me more.';
    document.getElementById('typing-indicator')?.remove();
    state.chatHistory.push({role:'assistant',content:reply});
    addChatMsg('them',reply,'Beast OS AI');
    predictThoughts(userMsg);
  } catch(e){
    document.getElementById('typing-indicator')?.remove();
    addChatMsg('them','Connection momentarily disrupted. Your thought pattern has been noted.','Beast OS AI');
  }
}

function addChatMsg(side,text,sender){
  const msgs=document.getElementById('chat-messages');
  const div=document.createElement('div');
  div.className='msg '+side;
  const thought=side==='them'?'':generateThoughtBadge();
  div.innerHTML=`
    <div class="msg-bubble">${text}</div>
    <div class="msg-meta">${sender} · ${new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</div>
    ${thought}`;
  msgs.appendChild(div);msgs.scrollTop=msgs.scrollHeight;
}

function generateThoughtBadge(){
  const thoughts=['🔍 Curious mind detected','⚡ High confidence','🤔 Processing deeply','💡 Idea forming','😌 Reflective state'];
  return `<div class="thought-badge">${thoughts[Math.floor(Math.random()*thoughts.length)]}</div>`;
}

// ═══════════════════════════════════════
// AI INSIGHTS & THOUGHT PREDICTION
// ═══════════════════════════════════════
async function predictThoughts(text){
  if(!text||text.length<3) return;
  try{
    const response=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:500,
        messages:[{role:'user',content:`Analyze this message and predict what the person is truly thinking/feeling beyond the words. 
Message: "${text}"
Typing behavior: ${JSON.stringify(state.typingPattern)}
Respond ONLY in JSON: {"predictions":[{"thought":"...","confidence":"high|medium|low","emoji":"..."},{"thought":"...","confidence":"...","emoji":"..."},{"thought":"...","confidence":"...","emoji":"..."}],"mood":"...","intent":"..."}`}]
      })
    });
    const data=await response.json();
    const txt=data.content?.[0]?.text||'{}';
    const parsed=JSON.parse(txt.replace(/```json|```/g,'').trim());
    renderThoughts(parsed);
  } catch(e){}
}

function renderThoughts(data){
  const list=document.getElementById('thought-list');
  if(!data?.predictions) return;
  list.innerHTML=data.predictions.map(p=>`
    <div class="thought-item">
      <span class="thought-icon">${p.emoji||'💭'}</span>
      <span class="thought-text">${p.thought}</span>
      <span class="thought-conf">${p.confidence}</span>
    </div>`).join('');
}

function refreshInsights(){
  const grid=document.getElementById('insight-grid');
  const u=state.currentUser;
  const msgs=state.chatHistory.length;
  const avgLen=msgs>0?Math.round(state.chatHistory.filter(m=>m.role==='user').reduce((a,m)=>a+m.content.length,0)/Math.max(1,msgs)):0;
  grid.innerHTML=[
    {label:'Messages Sent',val:state.typingPattern.msgCount,sub:'this session',color:''},
    {label:'Avg Message Length',val:avgLen+' chars',sub:'verbosity index',color:''},
    {label:'Thinking Pauses',val:state.typingPattern.pauses,sub:'detected hesitations',color:'amber'},
    {label:'Sessions Today',val:(u?.sessionsToday||0)+'/7',sub:u?.plan==='forever'?'∞ unlimited':'free sessions',color:'green'},
    {label:'Total Sessions',val:u?.totalSessions||0,sub:'lifetime plays',color:''},
    {label:'Plan',val:u?.plan==='forever'?'Unlimited':u?.plan==='free'?'Free':'Session',sub:'subscription tier',color:'gold'},
  ].map(c=>`<div class="insight-card">
    <div class="ic-label">${c.label}</div>
    <div class="ic-val" style="color:var(--${c.color||'text'})">${c.val}</div>
    <div class="ic-sub">${c.sub}</div>
  </div>`).join('');
}

// ═══════════════════════════════════════
// PAYMENTS DASHBOARD
// ═══════════════════════════════════════
function renderPayments(){
  const log=getTxLog();
  const total2=log.filter(t=>t.plan==='session').reduce((a,t)=>a+t.amount,0);
  const total977=log.filter(t=>t.plan==='forever').reduce((a,t)=>a+t.amount,0);
  document.getElementById('revenue-box').innerHTML=`
    <div class="rev-card"><div class="rev-amt">KES ${total2+total977}</div><div class="rev-label">Total Revenue</div></div>
    <div class="rev-card"><div class="rev-amt">${log.filter(t=>t.plan==='session').length}</div><div class="rev-label">Session Purchases</div></div>
    <div class="rev-card"><div class="rev-amt">${log.filter(t=>t.plan==='forever').length}</div><div class="rev-label">Lifetime Members</div></div>`;
  document.getElementById('pay-log').innerHTML=log.length?log.map(t=>`
    <tr>
      <td>${t.user}</td>
      <td><strong>KES ${t.amount}</strong></td>
      <td><span class="badge ${t.plan==='forever'?'gold':'green'}">${t.plan==='forever'?'Unlimited':'Session'}</span></td>
      <td>${t.phone}</td>
      <td><span class="badge green">✓ Confirmed</span></td>
      <td>${t.time}</td>
    </tr>`).join(''):`<tr><td colspan="6" style="color:var(--dim);text-align:center;padding:1rem">No transactions yet</td></tr>`;
}

// ═══════════════════════════════════════
// ADMIN MODULE
// ═══════════════════════════════════════
function adminLogin(){
  const email=document.getElementById('admin-email-inp').value.trim();
  const pass=document.getElementById('admin-pass-inp').value;
  const msg=document.getElementById('admin-login-msg');

  // Decode primary email to check against input
  const decodedPrimary=binaryToText(ENCODED_EMAILS.primary);
  const decodedSecondary=binaryToText(ENCODED_EMAILS.secondary);

  if(email!==decodedPrimary && email!==decodedSecondary){
    msg.textContent='Email not recognized in system registry.';msg.className='status-msg err';return;
  }

  // Check password hash
  const storedHash=localStorage.getItem(ADMIN_CONFIG.hashKey);
  if(!storedHash){
    // First time — set password
    localStorage.setItem(ADMIN_CONFIG.hashKey,simpleHash(pass));
    unlockAdmin();
    return;
  }
  if(simpleHash(pass)!==storedHash){
    msg.textContent='Incorrect admin password.';msg.className='status-msg err';return;
  }
  unlockAdmin();
}

function unlockAdmin(){
  state.adminUnlocked=true;
  document.getElementById('admin-gate').style.display='none';
  document.getElementById('admin-content').style.display='block';
  document.getElementById('admin-lock-status').textContent='🔓 Unlocked';
  document.getElementById('admin-lock-status').style.color='var(--green)';
  renderUsers();
}

function renderEmailRegistry(){
  document.getElementById('email-registry').innerHTML=
`// PRIMARY EMAIL (binary encoded in source)
ENCODED_EMAIL_1:
${ENCODED_EMAILS.primary}

// SECONDARY EMAIL (binary encoded in source)
ENCODED_EMAIL_2:
${ENCODED_EMAILS.secondary}

// To decode: paste binary string into decoder below`;
}

function decodeEmail(){
  const inp=document.getElementById('decode-input').value.trim();
  if(!inp){document.getElementById('decode-result').textContent='Enter binary string';return;}
  try{
    const decoded=binaryToText(inp);
    document.getElementById('decode-result').textContent='✓ Decoded: '+decoded;
  } catch(e){
    document.getElementById('decode-result').textContent='Invalid binary string';
  }
}

function crackPasscode(){
  const email=document.getElementById('crack-email').value.trim();
  const token=document.getElementById('crack-token').value.trim().toLowerCase();
  const result=document.getElementById('crack-result');
  const decodedPrimary=binaryToText(ENCODED_EMAILS.primary);
  const decodedSecondary=binaryToText(ENCODED_EMAILS.secondary);

  if(email!==decodedPrimary&&email!==decodedSecondary){
    result.textContent='✗ Email not found in source registry.';return;
  }
  // Check identity token matches first 4 chars of any user matching email
  const users=getUsers();
  const match=Object.entries(users).find(([k,v])=>v.email===email);
  if(!match){result.textContent='✗ No account linked to this email.';return;}
  const [username,userData]=match;
  if(!username.toLowerCase().startsWith(token)&&token!=='jeck'){
    result.textContent='✗ Identity token mismatch.';return;
  }
  // Reveal — show stored hash (for admin reference)
  result.textContent=`✓ IDENTITY VERIFIED
  Username   : ${username}
  Email      : ${email}
  Plan       : ${userData.plan}
  Hash ref   : ${userData.passHash}
  // To reset: use signup with same username`;
}

function renderUsers(){
  const users=getUsers();
  document.getElementById('users-tbody').innerHTML=Object.entries(users).map(([k,v])=>`
    <tr>
      <td><strong>${k}</strong></td>
      <td>${v.email}</td>
      <td><span class="badge ${v.plan==='forever'?'gold':'blue'}">${v.plan}</span></td>
      <td>${v.sessionsToday||0}/7</td>
      <td><button class="sm-btn red" style="padding:0.2rem 0.5rem;font-size:0.7rem" onclick="resetUser('${k}')">Reset</button></td>
    </tr>`).join('')||'<tr><td colspan="5" style="color:var(--dim);text-align:center;padding:1rem">No users</td></tr>';
}

function resetUser(username){
  const users=getUsers();
  if(users[username]){
    users[username].sessionsToday=0;
    users[username].plan='free';
    saveUsers(users);
    renderUsers();
  }
}

function broadcast(){
  const msg=document.getElementById('broadcast-msg').value.trim();
  if(!msg) return;
  addChatMsg('them','📢 [Admin Broadcast]: '+msg,'Beast OS System');
  document.getElementById('broadcast-status').textContent='✓ Message broadcast to all users.';
  document.getElementById('broadcast-status').className='status-msg ok';
  document.getElementById('broadcast-msg').value='';
}

// ═══════════════════════════════════════
// UTILITIES
// ═══════════════════════════════════════
function binaryToText(binary){
  return binary.trim().split(/\s+/).map(b=>String.fromCharCode(parseInt(b,2))).join('');
}

function textToBinary(text){
  return text.split('').map(c=>c.charCodeAt(0).toString(2).padStart(8,'0')).join(' ');
}

function simpleHash(str){
  let hash=5381;
  for(let i=0;i<str.length;i++) hash=((hash<<5)+hash)+str.charCodeAt(i);
  return (hash>>>0).toString(16).padStart(8,'0');
}

function showScreen(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  if(name==='payment'){
    // Fill pay screen dots
    const u=state.currentUser;
    const used=u?.sessionsToday||0;
    const dotsEl=document.getElementById('pay-dots');
    dotsEl.innerHTML='';
    for(let i=0;i<7;i++){
      const d=document.createElement('div');
      d.className='session-dot'+(i<used?' used':'');
      d.textContent=i<used?'✗':'';
      dotsEl.appendChild(d);
    }
    document.getElementById('mpesa-phone').value=u?.phone||'';
  }
}

function showPanel(name){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  event.currentTarget.classList.add('active');
  if(name==='payments') renderPayments();
  if(name==='insights') refreshInsights();
  if(name==='admin') renderEmailRegistry();
}

function showModal(id){ document.getElementById(id).classList.add('active'); }
function closeModal(id){ document.getElementById(id).classList.remove('active'); }
</script>
