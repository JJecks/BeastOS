<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BEAST OS · Communication Suite</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#0a0e1a;
  --surface:#111827;
  --surface2:#1a2236;
  --border:#1e2d47;
  --accent:#3b82f6;
  --accent2:#6366f1;
  --green:#10b981;
  --gold:#f59e0b;
  --red:#ef4444;
  --text:#e2e8f0;
  --dim:#64748b;
  --mpesa:#00a651;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Inter',sans-serif;
  min-height:100vh;
  overflow-x:hidden;
}
body::before{
  content:'';position:fixed;inset:0;
  background:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(59,130,246,0.08),transparent);
  pointer-events:none;z-index:0;
}

/* ── SCREENS ── */
.screen{display:none;position:relative;z-index:10;}
.screen.active{display:flex;flex-direction:column;min-height:100vh;}

/* ── AUTH SCREEN ── */
#screen-auth{align-items:center;justify-content:center;padding:2rem;}
.auth-box{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:12px;
  padding:2.5rem;
  width:100%;max-width:400px;
  box-shadow:0 20px 60px rgba(0,0,0,0.5);
}
.auth-logo{
  text-align:center;margin-bottom:2rem;
}
.auth-logo h1{
  font-family:'JetBrains Mono',monospace;
  font-size:1.8rem;font-weight:700;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.auth-logo p{color:var(--dim);font-size:0.8rem;letter-spacing:0.15em;margin-top:0.3rem;}
.auth-tabs{display:flex;margin-bottom:1.5rem;border-bottom:1px solid var(--border);}
.auth-tab{
  flex:1;padding:0.6rem;text-align:center;
  font-size:0.8rem;font-weight:600;letter-spacing:0.08em;
  color:var(--dim);cursor:pointer;border-bottom:2px solid transparent;
  transition:all 0.2s;text-transform:uppercase;
}
.auth-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.auth-form{display:none;}
.auth-form.active{display:block;}
label{display:block;font-size:0.75rem;font-weight:600;color:var(--dim);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.4rem;margin-top:1rem;}
input{
  width:100%;
  background:rgba(0,0,0,0.3);
  border:1px solid var(--border);
  color:var(--text);
  font-family:'Inter',sans-serif;
  font-size:0.9rem;
  padding:0.65rem 0.9rem;
  border-radius:6px;outline:none;
  transition:border-color 0.2s;
}
input:focus{border-color:var(--accent);}
.btn{
  width:100%;padding:0.75rem;
  border-radius:6px;border:none;
  font-family:'Inter',sans-serif;
  font-size:0.85rem;font-weight:600;
  cursor:pointer;transition:all 0.2s;
  margin-top:1.2rem;letter-spacing:0.05em;
}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;}
.btn-primary:hover{opacity:0.9;transform:translateY(-1px);box-shadow:0 4px 15px rgba(59,130,246,0.3);}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text);}
.btn-outline:hover{border-color:var(--accent);color:var(--accent);}
.status-msg{font-size:0.8rem;text-align:center;margin-top:0.8rem;min-height:1.2em;}
.status-msg.ok{color:var(--green);}
.status-msg.err{color:var(--red);}

/* ── PAYMENT SCREEN ── */
#screen-payment{align-items:center;justify-content:center;padding:2rem;}
.pay-box{
  background:var(--surface);border:1px solid var(--border);
  border-radius:12px;padding:2rem;width:100%;max-width:440px;
}
.pay-title{font-size:1.1rem;font-weight:700;margin-bottom:0.3rem;}
.pay-sub{font-size:0.8rem;color:var(--dim);margin-bottom:1.5rem;}
.plan-cards{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-bottom:1.5rem;}
.plan-card{
  background:var(--surface2);border:2px solid var(--border);
  border-radius:8px;padding:1rem;cursor:pointer;transition:all 0.2s;text-align:center;
}
.plan-card:hover,.plan-card.selected{border-color:var(--accent);background:rgba(59,130,246,0.08);}
.plan-card.gold{border-color:var(--gold);}
.plan-card.gold:hover,.plan-card.gold.selected{border-color:var(--gold);background:rgba(245,158,11,0.08);}
.plan-price{font-size:1.4rem;font-weight:700;color:var(--accent);}
.plan-price.gold{color:var(--gold);}
.plan-label{font-size:0.7rem;color:var(--dim);margin-top:0.2rem;}
.mpesa-row{
  background:rgba(0,166,81,0.08);border:1px solid rgba(0,166,81,0.3);
  border-radius:8px;padding:1rem;margin-bottom:1rem;
}
.mpesa-title{font-size:0.8rem;font-weight:700;color:var(--mpesa);margin-bottom:0.5rem;}
.sessions-bar{
  background:var(--surface2);border-radius:8px;padding:1rem;margin-bottom:1rem;
}
.sessions-dots{display:flex;gap:6px;margin-top:0.5rem;}
.session-dot{
  width:28px;height:28px;border-radius:50%;
  background:var(--green);border:2px solid var(--green);
  display:flex;align-items:center;justify-content:center;
  font-size:0.65rem;font-weight:700;color:#000;
  transition:all 0.3s;
}
.session-dot.used{background:var(--border);border-color:var(--border);color:var(--dim);}

/* ── MAIN APP ── */
#screen-app{flex-direction:row;}
/* Sidebar */
.sidebar{
  width:260px;min-width:260px;
  background:var(--surface);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  height:100vh;position:sticky;top:0;
}
.sidebar-header{
  padding:1rem;border-bottom:1px solid var(--border);
}
.app-brand{
  font-family:'JetBrains Mono',monospace;
  font-size:1rem;font-weight:700;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.user-pill{
  display:flex;align-items:center;gap:0.6rem;
  margin-top:0.7rem;padding:0.5rem;
  background:var(--surface2);border-radius:8px;
}
.avatar{
  width:32px;height:32px;border-radius:50%;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:0.8rem;color:#fff;flex-shrink:0;
}
.user-name{font-size:0.82rem;font-weight:600;truncate:ellipsis;}
.user-sub{font-size:0.68rem;color:var(--dim);}
.nav-list{flex:1;overflow-y:auto;padding:0.5rem;}
.nav-item{
  display:flex;align-items:center;gap:0.7rem;
  padding:0.6rem 0.8rem;border-radius:8px;
  cursor:pointer;transition:all 0.15s;
  font-size:0.85rem;font-weight:500;color:var(--dim);
  margin-bottom:2px;
}
.nav-item:hover{background:var(--surface2);color:var(--text);}
.nav-item.active{background:rgba(59,130,246,0.12);color:var(--accent);}
.nav-icon{font-size:1rem;width:20px;text-align:center;}
.sessions-mini{
  padding:0.8rem;border-top:1px solid var(--border);
  font-size:0.75rem;
}
.sessions-mini-label{color:var(--dim);margin-bottom:0.4rem;}
.mini-dots{display:flex;gap:4px;}
.mini-dot{
  width:22px;height:22px;border-radius:50%;
  background:var(--green);
  display:flex;align-items:center;justify-content:center;
  font-size:0.6rem;font-weight:700;color:#000;
}
.mini-dot.used{background:var(--border);}

/* ── PANELS ── */
.main-content{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.panel{display:none;flex:1;flex-direction:column;overflow:hidden;}
.panel.active{display:flex;}
.panel-header{
  padding:1rem 1.5rem;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  background:var(--surface);
}
.panel-title{font-size:1rem;font-weight:700;}
.panel-body{flex:1;overflow-y:auto;padding:1.5rem;}

/* ── CHAT PANEL ── */
.chat-messages{
  flex:1;overflow-y:auto;padding:1rem;
  display:flex;flex-direction:column;gap:0.8rem;
}
.msg{max-width:72%;display:flex;flex-direction:column;gap:2px;}
.msg.me{align-self:flex-end;align-items:flex-end;}
.msg.them{align-self:flex-start;align-items:flex-start;}
.msg-bubble{
  padding:0.6rem 0.9rem;border-radius:12px;
  font-size:0.88rem;line-height:1.5;
}
.msg.me .msg-bubble{
  background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;
  border-bottom-right-radius:3px;
}
.msg.them .msg-bubble{
  background:var(--surface2);color:var(--text);
  border-bottom-left-radius:3px;
}
.msg-meta{font-size:0.65rem;color:var(--dim);}
.thought-badge{
  font-size:0.68rem;padding:0.2rem 0.5rem;
  background:rgba(99,102,241,0.15);
  border:1px solid rgba(99,102,241,0.3);
  border-radius:20px;color:#a5b4fc;
  margin-top:2px;
}
.chat-input-row{
  padding:0.8rem 1rem;border-top:1px solid var(--border);
  display:flex;gap:0.6rem;align-items:flex-end;
  background:var(--surface);
}
.chat-input{
  flex:1;background:var(--surface2);border:1px solid var(--border);
  color:var(--text);font-family:'Inter',sans-serif;font-size:0.88rem;
  padding:0.6rem 0.9rem;border-radius:8px;outline:none;resize:none;
  max-height:120px;
}
.chat-input:focus{border-color:var(--accent);}
.send-btn{
  padding:0.6rem 1rem;border-radius:8px;border:none;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  color:#fff;cursor:pointer;font-weight:600;font-size:0.85rem;
  transition:all 0.2s;white-space:nowrap;
}
.send-btn:hover{opacity:0.9;}

/* ── AI INSIGHT PANEL ── */
.insight-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:1rem;margin-bottom:1.5rem;
}
.insight-card{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:1.1rem;
}
.ic-label{font-size:0.7rem;font-weight:600;color:var(--dim);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.4rem;}
.ic-val{font-size:1.3rem;font-weight:700;}
.ic-sub{font-size:0.72rem;color:var(--dim);margin-top:0.2rem;}
.thought-stream{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:1.1rem;margin-bottom:1rem;
}
.thought-item{
  padding:0.6rem 0;border-bottom:1px solid var(--border);
  font-size:0.83rem;display:flex;gap:0.6rem;align-items:flex-start;
}
.thought-item:last-child{border:none;}
.thought-icon{font-size:1rem;flex-shrink:0;}
.thought-text{line-height:1.5;}
.thought-conf{
  font-size:0.68rem;padding:0.15rem 0.4rem;border-radius:10px;
  background:rgba(99,102,241,0.15);color:#a5b4fc;margin-left:auto;flex-shrink:0;
}

/* ── PAYMENT ADMIN PANEL ── */
.pay-table{width:100%;border-collapse:collapse;font-size:0.82rem;}
.pay-table th{
  text-align:left;padding:0.6rem 0.8rem;
  font-size:0.7rem;font-weight:600;color:var(--dim);
  letter-spacing:0.08em;text-transform:uppercase;
  border-bottom:1px solid var(--border);
}
.pay-table td{padding:0.6rem 0.8rem;border-bottom:1px solid rgba(30,45,71,0.5);}
.badge{
  display:inline-block;padding:0.2rem 0.5rem;border-radius:20px;
  font-size:0.68rem;font-weight:600;
}
.badge.green{background:rgba(16,185,129,0.15);color:var(--green);}
.badge.gold{background:rgba(245,158,11,0.15);color:var(--gold);}
.badge.red{background:rgba(239,68,68,0.15);color:var(--red);}
.badge.blue{background:rgba(59,130,246,0.15);color:var(--accent);}
.revenue-box{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;
}
.rev-card{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:1rem;text-align:center;
}
.rev-amt{font-size:1.6rem;font-weight:700;color:var(--gold);}
.rev-label{font-size:0.7rem;color:var(--dim);margin-top:0.2rem;}

/* ── ADMIN MODULE ── */
.admin-section{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:1.2rem;margin-bottom:1rem;
}
.admin-section-title{
  font-size:0.78rem;font-weight:700;color:var(--dim);
  letter-spacing:0.12em;text-transform:uppercase;margin-bottom:1rem;
}
.code-block{
  background:#000;border:1px solid var(--border);border-radius:6px;
  padding:0.8rem;font-family:'JetBrains Mono',monospace;font-size:0.72rem;
  color:#00ff41;line-height:1.7;overflow-x:auto;white-space:pre-wrap;word-break:break-all;
}
.admin-input-row{display:flex;gap:0.6rem;margin-top:0.8rem;}
.admin-input{
  flex:1;background:rgba(0,0,0,0.3);border:1px solid var(--border);
  color:var(--text);font-family:'JetBrains Mono',monospace;
  font-size:0.8rem;padding:0.5rem 0.7rem;border-radius:6px;outline:none;
}
.admin-input:focus{border-color:var(--accent);}
.sm-btn{
  padding:0.5rem 1rem;border-radius:6px;border:none;
  font-size:0.78rem;font-weight:600;cursor:pointer;
  background:var(--accent);color:#fff;transition:all 0.2s;
  white-space:nowrap;
}
.sm-btn:hover{opacity:0.85;}
.sm-btn.green{background:var(--green);}
.sm-btn.red{background:var(--red);}
.decode-result{
  margin-top:0.6rem;padding:0.6rem;background:rgba(0,0,0,0.3);
  border-radius:6px;font-family:'JetBrains Mono',monospace;
  font-size:0.8rem;color:var(--green);min-height:2em;word-break:break-all;
}

/* TYPING INDICATOR */
.typing-indicator{display:flex;gap:4px;align-items:center;padding:0.4rem 0.6rem;}
.typing-dot{width:6px;height:6px;border-radius:50%;background:var(--dim);animation:typingBounce 1.2s infinite;}
.typing-dot:nth-child(2){animation-delay:0.2s;}
.typing-dot:nth-child(3){animation-delay:0.4s;}
@keyframes typingBounce{0%,60%,100%{transform:translateY(0);}30%{transform:translateY(-6px);}}

/* MODAL */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.7);
  z-index:1000;display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
}
.modal-overlay.active{display:flex;}
.modal{
  background:var(--surface);border:1px solid var(--border);
  border-radius:12px;padding:2rem;width:100%;max-width:400px;
  box-shadow:0 20px 60px rgba(0,0,0,0.5);
}
.modal-title{font-size:1rem;font-weight:700;margin-bottom:0.5rem;}
.modal-sub{font-size:0.82rem;color:var(--dim);margin-bottom:1.2rem;line-height:1.6;}
.modal-btns{display:flex;gap:0.6rem;margin-top:1.2rem;}
.modal-btns .btn{margin:0;flex:1;}

@media(max-width:700px){
  .sidebar{display:none;}
  .plan-cards{grid-template-columns:1fr;}
  .revenue-box{grid-template-columns:1fr 1fr;}
}
</style>
</head>
<body>

<!-- ═══════════ AUTH SCREEN ═══════════ -->
<div id="screen-auth" class="screen active">
  <div class="auth-box">
    <div class="auth-logo">
      <h1>⬡ BEAST OS</h1>
      <p>COMMUNICATION SUITE · v1.0</p>
    </div>
    <div class="auth-tabs">
      <div class="auth-tab active" onclick="switchAuthTab('login')">Sign In</div>
      <div class="auth-tab" onclick="switchAuthTab('signup')">Sign Up</div>
    </div>

    <!-- LOGIN -->
    <div id="auth-login" class="auth-form active">
      <label>Username</label>
      <input id="login-user" type="text" placeholder="Enter username"/>
      <label>Password</label>
      <input id="login-pass" type="password" placeholder="Enter password"/>
      <button class="btn btn-primary" onclick="doLogin()">Sign In</button>
      <div class="status-msg" id="login-msg"></div>
    </div>

    <!-- SIGNUP -->
    <div id="auth-signup" class="auth-form">
      <label>Username</label>
      <input id="signup-user" type="text" placeholder="Choose a username"/>
      <label>Email</label>
      <input id="signup-email" type="email" placeholder="your@email.com"/>
      <label>Password</label>
      <input id="signup-pass" type="password" placeholder="Choose a password"/>
      <label>Phone (for M-Pesa)</label>
      <input id="signup-phone" type="tel" placeholder="07XXXXXXXX"/>
      <button class="btn btn-primary" onclick="doSignup()">Create Account</button>
      <div class="status-msg" id="signup-msg"></div>
    </div>
  </div>
</div>

<!-- ═══════════ PAYMENT SCREEN ═══════════ -->
<div id="screen-payment" class="screen">
  <div class="pay-box">
    <div class="pay-title">🎮 Session Limit Reached</div>
    <div class="pay-sub" id="pay-screen-sub">You have used all 7 free sessions today. Unlock more to continue.</div>

    <div class="sessions-bar">
      <div style="font-size:0.75rem;color:var(--dim);font-weight:600;text-transform:uppercase;letter-spacing:0.08em">Today's Sessions</div>
      <div class="sessions-dots" id="pay-dots"></div>
    </div>

    <div class="plan-cards">
      <div class="plan-card selected" id="plan-session" onclick="selectPlan('session')">
        <div class="plan-price">KES 2</div>
        <div class="plan-label">1 Session</div>
        <div style="font-size:0.7rem;color:var(--dim);margin-top:0.4rem">Play once more</div>
      </div>
      <div class="plan-card gold" id="plan-forever" onclick="selectPlan('forever')">
        <div class="plan-price gold">KES 977</div>
        <div class="plan-label">Unlimited Forever</div>
        <div style="font-size:0.7rem;color:var(--dim);margin-top:0.4rem">Never pay again</div>
      </div>
    </div>

    <div class="mpesa-row">
      <div class="mpesa-title">📱 M-Pesa Payment</div>
      <label style="margin-top:0">M-Pesa Phone Number</label>
      <input id="mpesa-phone" type="tel" placeholder="07XXXXXXXX" style="margin-top:0.4rem"/>
      <div style="font-size:0.72rem;color:var(--dim);margin-top:0.5rem">An STK push will be sent to your phone</div>
    </div>

    <button class="btn btn-primary" onclick="processPay()" id="pay-btn">💳 Pay with M-Pesa</button>
    <button class="btn btn-outline" onclick="showScreen('app')" style="margin-top:0.5rem">← Back to App</button>
    <div class="status-msg" id="pay-msg"></div>
  </div>
</div>

<!-- ═══════════ MAIN APP ═══════════ -->
<div id="screen-app" class="screen">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="app-brand">⬡ BEAST OS</div>
      <div class="user-pill">
        <div class="avatar" id="sb-avatar">?</div>
        <div>
          <div class="user-name" id="sb-name">—</div>
          <div class="user-sub" id="sb-plan">Free Plan</div>
        </div>
      </div>
    </div>
    <div class="nav-list">
      <div class="nav-item active" onclick="showPanel('chat')"><span class="nav-icon">💬</span> Chat</div>
      <div class="nav-item" onclick="showPanel('insights')"><span class="nav-icon">🧠</span> AI Insights</div>
      <div class="nav-item" onclick="showPanel('payments')"><span class="nav-icon">💰</span> Payments</div>
      <div class="nav-item" onclick="showPanel('admin')"><span class="nav-icon">🔐</span> Admin</div>
      <div class="nav-item" onclick="doLogout()" style="margin-top:auto;color:var(--red)"><span class="nav-icon">↩</span> Logout</div>
    </div>
    <div class="sessions-mini">
      <div class="sessions-mini-label">Sessions today: <span id="sb-sessions">0</span>/7</div>
      <div class="mini-dots" id="sb-dots"></div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="main-content">

    <!-- CHAT PANEL -->
    <div id="panel-chat" class="panel active">
      <div class="panel-header">
        <div class="panel-title">💬 Communication</div>
        <div style="font-size:0.78rem;color:var(--dim)" id="ai-status-bar">AI thinking model: active</div>
      </div>
      <div class="chat-messages" id="chat-messages"></div>
      <div class="chat-input-row">
        <textarea class="chat-input" id="chat-input" rows="1" placeholder="Type a message..." oninput="onTyping(this)" onkeydown="chatKeydown(event)"></textarea>
        <button class="send-btn" onclick="sendMessage()">Send ↑</button>
      </div>
    </div>

    <!-- AI INSIGHTS PANEL -->
    <div id="panel-insights" class="panel">
      <div class="panel-header">
        <div class="panel-title">🧠 AI Thought Prediction</div>
        <button class="sm-btn" onclick="refreshInsights()">↻ Refresh</button>
      </div>
      <div class="panel-body">
        <div class="insight-grid" id="insight-grid"></div>
