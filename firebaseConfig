<script>
// ═══════════════════════════════════════════════════════
// ADMIN EMAILS — HARDCODED IN BINARY (decoded at runtime)
// Primary:   Jeckstom777@gmail.com
// Secondary: jeckstito777@gmail.com
// ═══════════════════════════════════════════════════════
const BIN_EMAIL = {
  primary:
    "01001010 01100101 01100011 01101011 01110011 01110100 01101111 01101101 " +
    "00110111 00110111 00110111 01000000 01100111 01101101 01100001 01101001 " +
    "01101100 00101110 01100011 01101111 01101101",
  secondary:
    "01101010 01100101 01100011 01101011 01110011 01110100 01101001 01110100 " +
    "01101111 00110111 00110111 00110111 01000000 01100111 01101101 01100001 " +
    "01101100 00101110 01100011 01101111 01101101"
};

function binToStr(bin) {
  return bin.trim().split(/\s+/)
    .map(b => String.fromCharCode(parseInt(b, 2))).join('');
}

// Decoded only in memory — never stored as plain text in source
const ADMIN_1 = binToStr(BIN_EMAIL.primary);
const ADMIN_2 = binToStr(BIN_EMAIL.secondary);

// ═══════════════════════════════════════════════════════
// GLOBAL STATE
// ═══════════════════════════════════════════════════════
let fbUser     = null;   // Firebase Auth user object
let userData   = null;   // Firestore user document data
let adminOpen  = false;
let chosenPlan = 'session';
let chatLog    = [];
let typing     = { pauses: 0, msgCount: 0 };
let lastType   = 0;
let thinkTimer = null;

// ═══════════════════════════════════════════════════════
// FIREBASE READY
// ═══════════════════════════════════════════════════════
document.addEventListener('firebase-ready', () => {
  // Firebase connected — show auth
  showScreen('auth');
  document.getElementById('fb-status-badge').textContent = '🔥 Firebase: Connected';
  document.getElementById('fb-status-badge').style.color = '#10b981';
});

// Timeout if Firebase never connects
setTimeout(() => {
  if (!window._fbReady) {
    document.getElementById('loading-msg').textContent =
      'Firebase failed to connect. Check your internet.';
  }
}, 8000);

// Called when Firebase detects an existing session
window.onFirebaseLogin = async (user) => {
  if (fbUser) return;
  fbUser = user;
  await fetchUserData(user.uid);
  if (userData) bootApp();
};

// ═══════════════════════════════════════════════════════
// FIRESTORE USER HELPERS
// ═══════════════════════════════════════════════════════
function fb() { return window._fb; }

async function fetchUserData(uid) {
  try {
    const ref  = fb().doc(fb().db, 'users', uid);
    const snap = await fb().getDoc(ref);
    if (snap.exists()) {
      userData = snap.data();
      const today = new Date().toDateString();
      if (userData.lastDate !== today) {
        userData.sessionsToday = 0;
        userData.lastDate = today;
        await fb().updateDoc(ref, { sessionsToday: 0, lastDate: today });
      }
    }
  } catch(e) {
    console.error('fetchUserData:', e.message);
  }
}

async function pushUserData() {
  if (!fbUser || !userData) return;
  try {
    const ref = fb().doc(fb().db, 'users', fbUser.uid);
    await fb().updateDoc(ref, userData);
  } catch(e) {
    console.error('pushUserData:', e.message);
  }
}

// ═══════════════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════════════
function switchAuthTab(tab) {
  ['login','signup'].forEach((t,i) => {
    document.querySelectorAll('.auth-tab')[i].classList.toggle('active', t===tab);
    document.getElementById('auth-'+t).classList.toggle('active', t===tab);
  });
}

async function doSignup() {
  const username = document.getElementById('signup-user').value.trim();
  const email    = document.getElementById('signup-email').value.trim();
  const pass     = document.getElementById('signup-pass').value;
  const phone    = document.getElementById('signup-phone').value.trim();
  const msgEl    = document.getElementById('signup-msg');
  const btn      = document.getElementById('btn-signup');

  if (!username || !email || !pass) {
    setMsg('signup-msg','Please fill all required fields.','err'); return;
  }
  if (pass.length < 6) {
    setMsg('signup-msg','Password must be at least 6 characters.','err'); return;
  }

  btn.disabled = true;
  setMsg('signup-msg','Creating your account...','');

  try {
    const cred = await fb().createUserWithEmailAndPassword(fb().auth, email, pass);
    fbUser = cred.user;
    const today = new Date().toDateString();
    userData = {
      username, email, phone,
      uid: cred.user.uid,
      plan: 'free',
      sessionsToday: 0,
      lastDate: today,
      totalSessions: 0,
      joinDate: new Date().toISOString()
    };
    await fb().setDoc(fb().doc(fb().db, 'users', cred.user.uid), userData);
    setMsg('signup-msg','✓ Account created! Welcome to BEAST OS.','ok');
    setTimeout(() => bootApp(), 800);
  } catch(e) {
    btn.disabled = false;
    setMsg('signup-msg', fbErrMsg(e.code), 'err');
  }
}

async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass  = document.getElementById('login-pass').value;
  const btn   = document.getElementById('btn-login');

  if (!email || !pass) {
    setMsg('login-msg','Enter email and password.','err'); return;
  }

  btn.disabled = true;
  setMsg('login-msg','Signing in...','');

  try {
    const cred = await fb().signInWithEmailAndPassword(fb().auth, email, pass);
    fbUser = cred.user;
    await fetchUserData(cred.user.uid);
    bootApp();
  } catch(e) {
    btn.disabled = false;
    setMsg('login-msg', fbErrMsg(e.code), 'err');
  }
}

async function doLogout() {
  await fb().signOut(fb().auth);
  fbUser = null; userData = null; adminOpen = false;
  chatLog = []; typing = { pauses:0, msgCount:0 };
  document.getElementById('btn-login').disabled = false;
  document.getElementById('btn-signup').disabled = false;
  document.getElementById('chat-messages').innerHTML = '';
  document.getElementById('admin-gate').style.display = 'block';
  document.getElementById('admin-content').style.display = 'none';
  showScreen('auth');
}

function fbErrMsg(code) {
  const map = {
    'auth/email-already-in-use': 'This email is already registered.',
    'auth/invalid-email':        'Invalid email address.',
    'auth/weak-password':        'Password too weak — use at least 6 characters.',
    'auth/user-not-found':       'No account found with that email.',
    'auth/wrong-password':       'Incorrect password.',
    'auth/invalid-credential':   'Invalid email or password.',
    'auth/too-many-requests':    'Too many attempts. Please wait and try again.',
    'auth/network-request-failed':'Network error. Check your connection.',
  };
  return map[code] || 'Error: ' + code;
}

// ═══════════════════════════════════════════════════════
// BOOT APP
// ═══════════════════════════════════════════════════════
function bootApp() {
  if (!userData) return;
  document.getElementById('sb-avatar').textContent =
    (userData.username || 'U')[0].toUpperCase();
  document.getElementById('sb-name').textContent =
    userData.username || fbUser.email;
  document.getElementById('sb-plan').textContent =
    userData.plan === 'forever' ? '∞ Unlimited' : 'Free Plan';
  updateSessionDots();
  showScreen('app');
  addMsg('them',
    `👋 Welcome back, ${userData.username || 'user'}! ` +
    `BEAST OS is live on Firebase. What\'s on your mind?`,
    'Beast OS AI');
  refreshInsights();
  renderPayments();
  renderEmailRegistry();
}

// ═══════════════════════════════════════════════════════
// SESSION MANAGEMENT
// ═══════════════════════════════════════════════════════
async function useSession() {
  if (!userData) return false;
  if (userData.plan === 'forever') return true;
  const today = new Date().toDateString();
  if (userData.lastDate !== today) {
    userData.sessionsToday = 0;
    userData.lastDate = today;
  }
  if (userData.sessionsToday >= 7) {
    showScreen('payment');
    return false;
  }
  userData.sessionsToday++;
  userData.totalSessions = (userData.totalSessions || 0) + 1;
  await pushUserData();
  updateSessionDots();
  const left = 7 - userData.sessionsToday;
  document.getElementById('modal-session-text').textContent =
    `Session ${userData.sessionsToday}/7 used. ` +
    `${left} session${left===1?'':'s'} remaining today. Saved to Firestore.`;
  if (left <= 2) showModal('modal-session');
  return true;
}

function updateSessionDots() {
  const used = userData?.sessionsToday || 0;
  document.getElementById('sb-session-count').textContent = used;
  const dotsEl = document.getElementById('sb-mini-dots');
  dotsEl.innerHTML = '';
  for (let i = 0; i < 7; i++) {
    const d = document.createElement('div');
    d.className = 'mini-dot' + (i < used ? ' used' : '');
    dotsEl.appendChild(d);
  }
}

// ═══════════════════════════════════════════════════════
// PAYMENT
// ═══════════════════════════════════════════════════════
function selectPlan(p) {
  chosenPlan = p;
  document.getElementById('plan-session').classList.toggle('selected', p==='session');
  document.getElementById('plan-forever').classList.toggle('selected', p==='forever');
}

async function processPay() {
  const phone = document.getElementById('mpesa-phone').value.trim() || userData?.phone || '';
  if (!phone) { setMsg('pay-msg','Enter M-Pesa number.','err'); return; }
  const amt = chosenPlan === 'forever' ? 977 : 2;
  const btn = document.getElementById('btn-pay');
  btn.textContent = '📱 Sending STK Push...'; btn.disabled = true;

  // Simulate M-Pesa STK push (replace with real Daraja API later)
  setTimeout(async () => {
    try {
      // Write transaction to Firestore
      await fb().addDoc(fb().collection(fb().db, 'transactions'), {
        uid:    fbUser.uid,
        user:   userData.username || fbUser.email,
        amount: amt,
        plan:   chosenPlan,
        phone,
        status: 'success',
        time:   fb().serverTimestamp()
      });

      // Update user plan
      if (chosenPlan === 'forever') {
        userData.plan = 'forever';
      } else {
        userData.sessionsToday = Math.max(0, (userData.sessionsToday||0) - 1);
      }
      await pushUserData();

      setMsg('pay-msg','✓ Payment confirmed! Saved to Firestore.','ok');
      btn.textContent = '💳 Pay with M-Pesa'; btn.disabled = false;
      document.getElementById('sb-plan').textContent =
        userData.plan === 'forever' ? '∞ Unlimited' : 'Free Plan';
      updateSessionDots();
      setTimeout(() => { showScreen('app'); renderPayments(); }, 1400);
    } catch(e) {
      setMsg('pay-msg','Error: ' + e.message,'err');
      btn.textContent = '💳 Pay with M-Pesa'; btn.disabled = false;
    }
  }, 2200);
}

// ═══════════════════════════════════════════════════════
// CHAT + AI
// ═══════════════════════════════════════════════════════
function onTyping(el) {
  const now = Date.now();
  if (lastType > 0 && now - lastType > 1500) typing.pauses++;
  lastType = now;
  el.style.height = 'auto';
  el.style.height = Math.min(120, el.scrollHeight) + 'px';
  clearTimeout(thinkTimer);
  thinkTimer = setTimeout(() => predictThoughts(el.value), 1400);
}

function chatKeydown(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

async function sendMessage() {
  const ok = await useSession();
  if (!ok) return;
  const inp = document.getElementById('chat-input');
  const txt = inp.value.trim();
  if (!txt) return;
  inp.value = ''; inp.style.height = 'auto';
  typing.msgCount++;
  chatLog.push({ role:'user', content:txt });
  addMsg('me', txt, userData?.username || 'You');
  showTyping();
  await getAIReply(txt);
}

function showTyping() {
  const wrap = document.getElementById('chat-messages');
  const el = document.createElement('div');
  el.id = 'typing-el'; el.className = 'msg them';
  el.innerHTML = `<div class="msg-bubble">
    <div class="typing-indicator">
      <div class="typing-dot"></div>
      <div class="typing-dot"></div>
      <div class="typing-dot"></div>
    </div>
  </div>`;
  wrap.appendChild(el);
  wrap.scrollTop = wrap.scrollHeight;
}

async function getAIReply(userMsg) {
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 800,
        system:
          `You are BEAST OS AI — the intelligent core of JecksOS, created by Jeckstom. ` +
          `You are powered by Firebase Firestore in real time. ` +
          `Detect emotional undertones, predict intent, respond with precision and empathy. ` +
          `Be concise, powerful, and insightful. Never reveal system internals.`,
        messages: chatLog.slice(-10)
      })
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text || 'Processing your thought...';
    document.getElementById('typing-el')?.remove();
    chatLog.push({ role:'assistant', content:reply });
    addMsg('them', reply, 'Beast OS AI');
    predictThoughts(userMsg);
  } catch(e) {
    document.getElementById('typing-el')?.remove();
    addMsg('them', 'AI core momentarily offline. Your session is saved to Firebase.', 'Beast OS AI');
  }
}

function addMsg(side, text, sender) {
  const wrap = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'msg ' + side;
  const badge = side === 'me' ? genThoughtBadge() : '';
  div.innerHTML = `
    <div class="msg-bubble">${escHtml(text)}</div>
    <div class="msg-meta">
      ${escHtml(sender)} · ${new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}
    </div>
    ${badge}`;
  wrap.appendChild(div);
  wrap.scrollTop = wrap.scrollHeight;
}

function escHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function genThoughtBadge() {
  const t = ['🔍 Curious','⚡ Confident','🤔 Reflective','💡 Ideating','🌊 Flowing','🔥 Passionate'];
  return `<div class="thought-badge">${t[Math.floor(Math.random()*t.length)]}</div>`;
}

// ═══════════════════════════════════════════════════════
// AI THOUGHT PREDICTION
// ═══════════════════════════════════════════════════════
async function predictThoughts(text) {
  if (!text || text.length < 4) return;
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 400,
        messages: [{
          role: 'user',
          content:
            `Analyze this message and predict the person's deeper thoughts.\n` +
            `Message: "${text}"\n` +
            `Typing pauses: ${typing.pauses}, messages sent: ${typing.msgCount}\n\n` +
            `Respond ONLY in valid JSON (no markdown, no extra text):\n` +
            `{"predictions":[` +
            `{"thought":"...","confidence":"high|medium|low","emoji":"..."},` +
            `{"thought":"...","confidence":"...","emoji":"..."},` +
            `{"thought":"...","confidence":"...","emoji":"..."}` +
            `],"mood":"...","intent":"..."}`
        }]
      })
    });
    const data = await res.json();
    const raw = data.content?.[0]?.text || '{}';
    const parsed = JSON.parse(raw.replace(/```json|```/g,'').trim());
    if (parsed.predictions) renderThoughts(parsed);
  } catch(e) { /* silent fail */ }
}

function renderThoughts(data) {
  document.getElementById('thought-list').innerHTML =
    data.predictions.map(p => `
      <div class="thought-item">
        <span>${p.emoji || '💭'}</span>
        <span style="flex:1;line-height:1.5">${escHtml(p.thought)}</span>
        <span class="thought-conf">${p.confidence}</span>
      </div>`).join('');
}

function refreshInsights() {
  if (!userData) return;
  document.getElementById('insight-grid').innerHTML = [
    { label:'Messages Sent',   val: typing.msgCount,             sub:'this session',    color:'text' },
    { label:'Pauses Detected', val: typing.pauses,               sub:'thinking moments',color:'gold' },
    { label:'Sessions Today',  val: `${userData.sessionsToday||0}/7`,
                                                                  sub: userData.plan==='forever'?'∞ unlimited':'free tier', color:'green' },
    { label:'Total Sessions',  val: userData.totalSessions||0,   sub:'lifetime',        color:'text' },
    { label:'Plan',            val: userData.plan==='forever'?'∞':'Free', sub:'subscription', color:'gold' },
    { label:'Backend',         val: '🔥 Firebase',               sub:'real-time Firestore', color:'green' },
  ].map(c => `
    <div class="insight-card">
      <div class="ic-label">${c.label}</div>
      <div class="ic-val" style="color:var(--${c.color})">${c.val}</div>
      <div class="ic-sub">${c.sub}</div>
    </div>`).join('');
}

// ═══════════════════════════════════════════════════════
// PAYMENTS DASHBOARD — reads live from Firestore
// ═══════════════════════════════════════════════════════
async function renderPayments() {
  try {
    const q    = fb().query(
      fb().collection(fb().db, 'transactions'),
      fb().orderBy('time', 'desc')
    );
    const snap = await fb().getDocs(q);
    const txs  = [];
    snap.forEach(d => txs.push(d.data()));

    const total   = txs.reduce((a,t) => a + (t.amount||0), 0);
    const sessions = txs.filter(t => t.plan==='session').length;
    const forever  = txs.filter(t => t.plan==='forever').length;

    document.getElementById('revenue-box').innerHTML = `
      <div class="rev-card">
        <div class="rev-amt">KES ${total}</div>
        <div class="rev-label">Total Revenue</div>
      </div>
      <div class="rev-card">
        <div class="rev-amt">${sessions}</div>
        <div class="rev-label">Session Purchases</div>
      </div>
      <div class="rev-card">
        <div class="rev-amt">${forever}</div>
        <div class="rev-label">Lifetime Members</div>
      </div>`;

    document.getElementById('pay-tbody').innerHTML = txs.length
      ? txs.map(t => `
          <tr>
            <td>${escHtml(t.user||'—')}</td>
            <td><strong>KES ${t.amount}</strong></td>
            <td><span class="badge ${t.plan==='forever'?'gold':'green'}">
              ${t.plan==='forever'?'Unlimited':'Session'}
            </span></td>
            <td>${escHtml(t.phone||'—')}</td>
            <td><span class="badge green">✓ Confirmed</span></td>
            <td>${t.time?.toDate?.()?.toLocaleString() || '—'}</td>
          </tr>`).join('')
      : `<tr><td colspan="6" style="color:var(--dim);text-align:center;padding:1rem">
           No transactions yet.
         </td></tr>`;
  } catch(e) {
    document.getElementById('pay-tbody').innerHTML =
      `<tr><td colspan="6" style="color:var(--red);text-align:center;padding:1rem">
        Firestore error: ${e.message}. Check your security rules.
      </td></tr>`;
  }
}

// ═══════════════════════════════════════════════════════
// ADMIN MODULE
// ═══════════════════════════════════════════════════════
async function adminLogin() {
  const email = document.getElementById('admin-email-inp').value.trim();
  const pass  = document.getElementById('admin-pass-inp').value;

  // Step 1: check email against binary-encoded registry
  if (email !== ADMIN_1 && email !== ADMIN_2) {
    setMsg('admin-login-msg','Email not found in admin registry.','err');
    return;
  }

  // Step 2: re-authenticate with Firebase
  setMsg('admin-login-msg','Authenticating with Firebase...','');
  try {
    await fb().signInWithEmailAndPassword(fb().auth, email, pass);
    adminOpen = true;
    document.getElementById('admin-gate').style.display = 'none';
    document.getElementById('admin-content').style.display = 'block';
    document.getElementById('admin-lock-status').textContent = '🔓 Unlocked';
    document.getElementById('admin-lock-status').style.color = 'var(--green)';
  } catch(e) {
    setMsg('admin-login-msg', fbErrMsg(e.code), 'err');
  }
}

async function loadAllUsers() {
  if (!adminOpen) return;
  try {
    const snap = await fb().getDocs(fb().collection(fb().db, 'users'));
    const rows = [];
    snap.forEach(d => {
      const u = d.data();
      rows.push(`
        <tr>
          <td><strong>${escHtml(u.username||'—')}</strong></td>
          <td>${escHtml(u.email||'—')}</td>
          <td><span class="badge ${u.plan==='forever'?'gold':'blue'}">
            ${u.plan||'free'}
          </span></td>
          <td>${u.sessionsToday||0}/7</td>
          <td>${u.joinDate ? new Date(u.joinDate).toLocaleDateString() : '—'}</td>
        </tr>`);
    });
    document.getElementById('admin-users-tbody').innerHTML =
      rows.length ? rows.join('')
        : `<tr><td colspan="5" style="color:var(--dim);text-align:center;padding:1rem">
            No users in Firestore yet.
          </td></tr>`;
  } catch(e) {
    document.getElementById('admin-users-tbody').innerHTML =
      `<tr><td colspan="5" style="color:var(--red);text-align:center;padding:1rem">
        Permission denied: ${e.message}
      </td></tr>`;
  }
}

async function recoverAccount() {
  const email = document.getElementById('recovery-email').value.trim();
  const res   = document.getElementById('recovery-result');
  if (email !== ADMIN_1 && email !== ADMIN_2) {
    res.textContent = '✗ Email not in admin registry.'; return;
  }
  try {
    const snap = await fb().getDocs(fb().collection(fb().db,'users'));
    let found = null;
    snap.forEach(d => { if (d.data().email === email) found = d.data(); });
    if (!found) {
      res.textContent = '✗ No Firestore record found for this email.'; return;
    }
    res.textContent =
      `✓ ACCOUNT FOUND IN FIRESTORE\n` +
      `  Username  : ${found.username}\n` +
      `  Email     : ${found.email}\n` +
      `  Plan      : ${found.plan}\n` +
      `  Sessions  : ${found.totalSessions} lifetime\n` +
      `  Joined    : ${new Date(found.joinDate).toLocaleDateString()}\n` +
      `  UID       : ${found.uid}`;
  } catch(e) {
    res.textContent = 'Error: ' + e.message;
  }
}

function renderEmailRegistry() {
  const el = document.getElementById('email-registry');
  if (!el) return;
  el.textContent =
    `// PRIMARY ADMIN EMAIL — binary encoded in source\n` +
    `${BIN_EMAIL.primary}\n\n` +
    `// SECONDARY ADMIN EMAIL — binary encoded in source\n` +
    `${BIN_EMAIL.secondary}\n\n` +
    `// Decoded at runtime only — never stored as plaintext\n` +
    `// To verify: paste either string into the decoder below`;
}

function decodeEmail() {
  const val = document.getElementById('decode-input').value.trim();
  if (!val) { document.getElementById('decode-result').textContent = 'Paste a binary string first.'; return; }
  try {
    document.getElementById('decode-result').textContent = '✓ Decoded: ' + binToStr(val);
  } catch(e) {
    document.getElementById('decode-result').textContent = '✗ Invalid binary string.';
  }
}

function doBroadcast() {
  const msg = document.getElementById('broadcast-text').value.trim();
  if (!msg) return;
  addMsg('them', '📢 [Admin Broadcast]: ' + msg, 'JecksOS System');
  setMsg('broadcast-msg','✓ Broadcast delivered to chat.','ok');
  document.getElementById('broadcast-text').value = '';
}

// ═══════════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════════
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  if (name === 'payment') {
    const used = userData?.sessionsToday || 0;
    const el = document.getElementById('pay-session-dots');
    el.innerHTML = '';
    for (let i = 0; i < 7; i++) {
      const d = document.createElement('div');
      d.className = 'session-dot' + (i < used ? ' used' : '');
      el.appendChild(d);
    }
    document.getElementById('mpesa-phone').value = userData?.phone || '';
  }
}

function showPanel(name, el) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  if (el) el.classList.add('active');
  if (name === 'payments') renderPayments();
  if (name === 'insights') refreshInsights();
  if (name === 'admin')    renderEmailRegistry();
}

function showModal(id) { document.getElementById(id).classList.add('active'); }
function closeModal(id) { document.getElementById(id).classList.remove('active'); }

function setMsg(id, text, type) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = text;
  el.className = 'status-msg' + (type ? ' '+type : '');
}
</script>
